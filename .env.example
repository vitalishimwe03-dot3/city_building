NODE_ENV=production
DB_PATH=/data/city_building.db
SESSION_SECRET=<generate-a-random-string>
EMAIL_USER=citybuildingengineeringcompany@gmail.com
EMAIL_PASS=<your-gmail-app-password>
ADMIN_EMAIL=citybuildingengineeringcompany@gmail.com
EMAIL_SERVICE=gmail

# Google OAuth 2.0 (required for "Sign in with Gmail")
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-client-secret
# BASE_URL=https://your-production-domain.com

# --- ADVERTISEMENTS (Action-Based Earning) ---
# These earn money when users CLICK, BUY, or SIGN UP

# 1. Google AdSense (Pay Per Click)
# Get your ID from https://adsense.google.com
# ADSENSE_PUBLISHER_ID=1234567890123456
# ADSENSE_SLOT_TOP_BANNER=1234567890
# ADSENSE_SLOT_FOOTER_BANNER=1234567891
# ADSENSE_SLOT_IN_CONTENT=1234567892

# 2. Amazon Affiliate (Commission per sale)
# Sign up at https://affiliate-program.amazon.com
# AMAZON_AFFILIATE_ID=your-tag-20
# AFFILIATE_AMAZON_BOOKS_LINK=https://www.amazon.com/s?k=revit+training+books&tag=your-tag-20

# 3. Udemy Affiliate (Commission per enrollment)
# Sign up at https://www.udemy.com/affiliate/
# UDEMY_REFERRAL_CODE=yourCode
# AFFILIATE_UDEMY_LINK=https://www.udemy.com/course/revit-beginners/?referralCode=yourCode

# 4. Lead Generation (Pay per form submit)
# LEADGEN_FORM_ID=your-form-id
# LEADGEN_FORM_URL=https://your-form-url.com/submit

# 5. Toggle ad slots on/off (default: true)
# ADS_SHOW_TOP_BANNER=true
# ADS_SHOW_FOOTER_BANNER=true
# ADS_SHOW_IN_CONTENT=true
# ADS_SHOW_AFFILIATE=true
# ADS_SHOW_SPONSORED=true
