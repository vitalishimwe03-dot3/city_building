<section id="courses" class="section">
  <div class="container">
    <div class="section-heading text-center mb-5">
      <p class="text-uppercase fw-semibold mb-2">
        <i class="bi bi-grid-3x3-gap-fill me-1"></i> Our Courses
      </p>
      <h2>Explore Professional Training</h2>
      <p class="text-muted mx-auto" style="max-width: 720px;">Browse our software tracks and select a training path to view available softwares.</p>
      <div class="mx-auto mt-4" style="max-width: 500px; position: relative;">
        <input type="text" id="liveSearch" class="form-control form-control-lg" placeholder="Search courses..." autocomplete="off">
        <div id="searchResults" class="list-group d-none position-absolute w-100 shadow" style="z-index: 1000; max-height: 400px; overflow-y: auto;"></div>
      </div>
    </div>

    <div class="row g-4">
      <% if (categories.length === 0) { %>
        <div class="col-12">
          <div class="alert alert-info"><i class="bi bi-info-circle me-2"></i>No courses are available yet. Please check back later.</div>
        </div>
      <% } %>
      <% categories.forEach(category => { %>
        <div class="col-md-6 col-lg-4">
          <div class="card category-card h-100 border-0">
            <div class="card-body d-flex flex-column">
              <div class="d-flex align-items-center gap-2 mb-2">
                <i class="bi bi-bookmark-fill" style="color: var(--accent-light);"></i>
                <h3 class="h5 mb-0"><%= category.name %></h3>
              </div>
              <p class="text-muted flex-grow-1"><%= category.description %></p>
              <a href="/category/<%= category.slug %>" class="btn btn-primary">
                <i class="bi bi-arrow-right"></i> View Softwares
              </a>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</section>

<section class="section" style="background: var(--bg-secondary);">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <div class="section-label">Why Choose Us</div>
        <h2 class="section-title">Why City Building training works</h2>
        <p class="section-desc">Practical project-based learning for architects, engineers, designers and surveyors. Each training track includes current tools used in the Rwandan and international building industry.</p>
        <ul class="list-unstyled feature-list">
          <li>
            <span class="badge rounded-pill me-2" style="background: linear-gradient(135deg, var(--accent), var(--accent-light)); color:#fff;">01</span>
            Hands-on workspace simulations.
          </li>
          <li>
            <span class="badge rounded-pill me-2" style="background: linear-gradient(135deg, var(--accent), var(--accent-light)); color:#fff;">02</span>
            Industry software for real tasks.
          </li>
          <li>
            <span class="badge rounded-pill me-2" style="background: linear-gradient(135deg, var(--accent), var(--accent-light)); color:#fff;">03</span>
            Internship-ready curriculum.
          </li>
        </ul>
      </div>
      <div class="col-lg-6">
        <div class="contact-card p-4">
          <div class="d-flex align-items-center gap-2 mb-3">
            <i class="bi bi-pencil-square" style="font-size: 1.5rem; color: var(--accent-light);"></i>
            <h3 class="h4 fw-bold mb-0">Apply now</h3>
          </div>
          <p class="text-muted">Send your details and one of our advisors will contact you for registration and internship placement.</p>
          <form id="applyForm" action="https://formspree.io/f/xnjyzgjr" method="POST" class="row g-3">
            <input type="hidden" name="_subject" value="New course enquiry from City Building website">
            <div data-fs-success class="alert alert-success d-none" role="alert">
              <i class="bi bi-check-circle me-1"></i> Thank you! We'll be in touch soon.
            </div>
            <div data-fs-error class="alert alert-danger d-none" role="alert"></div>
            <div class="col-12">
              <input type="text" class="form-control" name="name" placeholder="Your name" data-fs-field required>
              <span data-fs-error="name" class="invalid-feedback"></span>
            </div>
            <div class="col-md-6">
              <input type="email" class="form-control" name="email" placeholder="Email address" data-fs-field required>
              <span data-fs-error="email" class="invalid-feedback"></span>
            </div>
            <div class="col-md-6">
              <input type="tel" class="form-control" name="phone" placeholder="Phone number" data-fs-field required>
              <span data-fs-error="phone" class="invalid-feedback"></span>
            </div>
            <div class="col-12">
              <select name="course" class="form-control" data-fs-field required>
                <option value="">-- Select a course type --</option>
                <% if (categories && categories.length > 0) { %>
                  <% categories.forEach(cat => { %>
                    <option value="<%= cat.name %>"><%= cat.name %></option>
                  <% }); %>
                <% } %>
              </select>
              <span data-fs-error="course" class="invalid-feedback"></span>
            </div>
            <div class="col-12">
              <textarea class="form-control" name="message" rows="4" placeholder="Message (optional)" data-fs-field></textarea>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary w-100" data-fs-submit-btn>
                <i class="bi bi-send"></i> Send enquiry
              </button>
            </div>
          </form>
        </div>
      </div>
      <script>
        window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };
        formspree('initForm', { formElement: '#applyForm', formId: 'xnjyzgjr' });
      </script>
    </div>
  </div>
</section>

