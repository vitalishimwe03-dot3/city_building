<section class="hero" id="home">
  <div class="hero-slider" id="heroSlider"></div>
  <div class="hero-slider-dots" id="heroDots"></div>
  <div class="container">
    <div class="row align-items-center" style="min-height: 90vh;">
      <div class="col-12 col-lg-7">
        <div class="hero-badge">
          <i class="bi bi-geo-alt-fill"></i>
          Kigali, Rwanda — May 2026 Intake
        </div>
        <h1 class="hero-title">
          Build Your <span class="highlight">Engineering</span> Career
        </h1>
        <p class="hero-subtitle">
          Professional software training in AutoCAD, Revit, ETABS, Lumion and more.
          Hands-on courses designed for architects, engineers, and designers in Rwanda.
        </p>
        <div class="hero-actions">
          <a href="/category/architecture" class="btn btn-primary btn-lg">
            <i class="bi bi-compass"></i> Explore Courses
          </a>
          <a href="/contact" class="btn btn-outline btn-lg">
            <i class="bi bi-chat-dots"></i> Enquire Now
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <h3>10+</h3>
            <p>Courses</p>
          </div>
          <div class="hero-stat">
            <h3>500+</h3>
            <p>Graduates</p>
          </div>
          <div class="hero-stat">
            <h3>5★</h3>
            <p>Training</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-slider-dots {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 5;
  display: flex;
  gap: 6px;
  max-width: 92%;
  overflow-x: auto;
  padding: 4px 12px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.hero-slider-dots::-webkit-scrollbar { display: none; }
.hero-slider-dots .dot {
  min-width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1.5px solid transparent;
  flex-shrink: 0;
}
.hero-slider-dots .dot.active {
  background: var(--accent);
  border-color: rgba(255,255,255,0.6);
  transform: scale(1.3);
}
[data-theme="light"] .hero-slider-dots .dot {
  background: rgba(0,0,0,0.2);
}
[data-theme="light"] .hero-slider-dots .dot.active {
  background: var(--accent);
  border-color: rgba(0,0,0,0.25);
}
</style>

<script>
(function() {
  var container = document.getElementById('heroSlider');
  var dotsContainer = document.getElementById('heroDots');
  var current = 0;
  var intervalId = null;
  var slides = [];

  var fallbackSlides = [
    {img:'https://images.unsplash.com/photo-1487958449943-2429e8be8625?w=1920&q=80'},
    {img:'https://images.unsplash.com/photo-1486325212027-8081e485255e?w=1920&q=80'},
    {img:'https://images.unsplash.com/photo-1503387762519-52582b8ba3f0?w=1920&q=80'},
    {img:'https://images.unsplash.com/photo-1518005020951-eccb494ad742?w=1920&q=80'},
    {img:'https://images.unsplash.com/photo-1464146072230-91cabc968266?w=1920&q=80'},
    {img:'https://images.unsplash.com/photo-1513828583688-c52646db42da?w=1920&q=80'},
    {img:'https://images.unsplash.com/photo-1519501025264-65ba15a82390?w=1920&q=80'},
    {img:'https://images.unsplash.com/photo-1533547271690-6b6c1f4ea06b?w=1920&q=80'}
  ];

  function goToSlide(index) {
    var els = container.querySelectorAll('.hero-slide');
    var dots = dotsContainer.querySelectorAll('.dot');
    if (!els.length) return;
    if (els[current]) els[current].classList.remove('active');
    if (dots[current]) dots[current].classList.remove('active');
    current = index;
    if (els[current]) els[current].classList.add('active');
    if (dots[current]) dots[current].classList.add('active');
  }
  function nextSlide() { goToSlide((current + 1) % slides.length); }
  function start() { if (intervalId) clearInterval(intervalId); intervalId = setInterval(nextSlide, slides[0]?.transition_speed || 5000); }
  function stop() { if (intervalId) { clearInterval(intervalId); intervalId = null; } }

  function buildSlides(slideData) {
    slides = slideData;
    container.innerHTML = '';
    dotsContainer.innerHTML = '';
    if (!slides.length) slides = fallbackSlides;
    slides.forEach(function(item, i) {
      var div = document.createElement('div');
      div.className = 'hero-slide' + (i === 0 ? ' active' : '');
      container.appendChild(div);
      var dot = document.createElement('span');
      dot.className = 'dot' + (i === 0 ? ' active' : '');
      dot.setAttribute('role', 'button');
      dot.setAttribute('aria-label', 'Slide ' + (i + 1));
      dot.addEventListener('click', function() { stop(); goToSlide(i); start(); });
      dotsContainer.appendChild(dot);
      if (item.image) {
        var img = new Image();
        img.onload = function() { div.style.background = 'url(' + item.image + ') center/cover no-repeat'; };
        img.onerror = function() { div.style.background = 'linear-gradient(135deg,#0a1628,#1a365d,#0e7490)'; };
        img.src = item.image;
      } else {
        div.style.background = 'linear-gradient(135deg,#0a1628,#1a365d,#0e7490)';
      }
    });
    start();
  }

  fetch('/api/slides').then(function(r){ return r.json(); }).then(function(d){
    if (d.success && d.slides.length) buildSlides(d.slides);
    else buildSlides(fallbackSlides);
  }).catch(function(){ buildSlides(fallbackSlides); });

  var hero = document.getElementById('home');
  if (hero) {
    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', start);
  }
})();
</script>

