              <input type="text" class="form-control" name="name" placeholder="Your name" data-fs-field required>
              <span data-fs-error="name" class="invalid-feedback"></span>
            </div>
            <div class="col-md-6">
              <input type="email" class="form-control" name="email" placeholder="Email address" data-fs-field required>
              <span data-fs-error="email" class="invalid-feedback"></span>
            </div>
            <div class="col-md-6">
              <input type="tel" class="form-control" name="phone" placeholder="Phone number" data-fs-field required>
