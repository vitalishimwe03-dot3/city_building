              <span data-fs-error="course" class="invalid-feedback"></span>
            </div>
            <div class="col-12">
              <textarea class="form-control" name="message" rows="4" placeholder="Message (optional)" data-fs-field></textarea>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary w-100" data-fs-submit-btn>
                <i class="bi bi-send"></i> Send enquiry
              </button>
            </div>
          </form>
        </div>
      </div>
      <script>
        window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };
        formspree('initForm', { formElement: '#applyForm', formId: 'xnjyzgjr' });
      </script>
    </div>
