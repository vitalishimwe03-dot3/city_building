    <div id="testimonialsCarousel" class="row g-4 justify-content-center">
      <div class="col-12 text-center py-4 text-muted">
        <div class="spinner-border spinner-border-sm me-2" role="status"></div> Loading testimonials...
      </div>
    </div>
  </div>
