<script>
document.addEventListener('DOMContentLoaded', function() {
  fetch('/api/testimonials').then(function(r) { return r.json(); }).then(function(data) {
    var container = document.getElementById('testimonialsCarousel');
    if (!container) return;
    if (!data || data.length === 0) {
      container.innerHTML = '<div class="col-12 text-center py-4 text-muted"><p>Testimonials coming soon. Enroll today and share your experience!</p></div>';
      return;
    }
    var html = '';
    data.forEach(function(t) {
      var stars = '';
      for (var i = 1; i <= 5; i++) {
        stars += '<i class="bi ' + (i <= (t.rating || 5) ? 'bi-star-fill' : 'bi-star') + '" style="color:#f59e0b;font-size:0.9rem;"></i>';
      }
      html += '<div class="col-md-6 col-lg-4">' +
        '<div class="card h-100 border-0" style="background:var(--bg-card);border:1px solid var(--border);">' +
          '<div class="card-body p-4 d-flex flex-column">' +
            '<div class="mb-2">' + stars + '</div>' +
            '<p class="card-text flex-grow-1 fst-italic" style="color:var(--text-secondary);">"' + escHtml(t.content) + '"</p>' +
            '<div class="d-flex align-items-center gap-3 mt-3 pt-3" style="border-top:1px solid var(--border);">' +
              '<div style="width:44px;height:44px;border-radius:50%;background:linear-gradient(135deg,var(--accent),var(--accent-light));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;font-size:1.2rem;flex-shrink:0;">' + (t.student_name ? t.student_name.charAt(0).toUpperCase() : 'S') + '</div>' +
              '<div class="text-start">' +
                '<strong class="d-block">' + escHtml(t.student_name) + '</strong>' +
                (t.student_title ? '<small class="text-muted">' + escHtml(t.student_title) + '</small>' : '') +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>' +
      '</div>';
    });
    container.innerHTML = html;
  }).catch(function() {
    var container = document.getElementById('testimonialsCarousel');
    if (container) {
      container.innerHTML = '<div class="col-12 text-center py-4 text-muted"><p>Testimonials coming soon.</p></div>';
    }
  });
});

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
