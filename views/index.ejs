<section class="hero" id="home">
  <div class="hero-slider" id="heroSlider"></div>
  <div class="hero-slider-dots" id="heroDots"></div>
  <div class="container">
    <div class="row align-items-center" style="min-height: 90vh;">
      <div class="col-12 col-lg-7">
        <div class="hero-badge">
          <i class="bi bi-geo-alt-fill"></i>
          Kigali, Rwanda — May 2026 Intake
        </div>
        <h1 class="hero-title">
          Build Your <span class="highlight">Engineering</span> Career
        </h1>
        <p class="hero-subtitle">
          Professional software training in AutoCAD, Revit, ETABS, Lumion and more.
          Hands-on courses designed for architects, engineers, and designers in Rwanda.
        </p>
        <div class="hero-actions">
          <a href="/category/architectural" class="btn btn-primary btn-lg">
            <i class="bi bi-compass"></i> Explore Courses
          </a>
          <a href="/contact" class="btn btn-outline btn-lg">
            <i class="bi bi-chat-dots"></i> Enquire Now
          </a>
        </div>
        <div class="hero-stats">
          <div class="hero-stat">
            <h3>10+</h3>
            <p>Courses</p>
          </div>
          <div class="hero-stat">
            <h3>500+</h3>
            <p>Graduates</p>
          </div>
          <div class="hero-stat">
            <h3>5★</h3>
            <p>Training</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.hero-slider-dots {
  position: absolute;
  bottom: 16px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 5;
  display: flex;
  gap: 6px;
  max-width: 92%;
  overflow-x: auto;
  padding: 4px 12px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.hero-slider-dots::-webkit-scrollbar { display: none; }
.hero-slider-dots .dot {
  min-width: 8px;
  height: 8px;
  border-radius: 50%;
  background: rgba(255,255,255,0.4);
  cursor: pointer;
  transition: all 0.3s ease;
  border: 1.5px solid transparent;
  flex-shrink: 0;
}
.hero-slider-dots .dot.active {
  background: var(--accent);
  border-color: rgba(255,255,255,0.6);
  transform: scale(1.3);
}
[data-theme="light"] .hero-slider-dots .dot {
  background: rgba(0,0,0,0.2);
}
[data-theme="light"] .hero-slider-dots .dot.active {
  background: var(--accent);
  border-color: rgba(0,0,0,0.25);
}
</style>

<script>
(function() {
  var slides = [
    {bg:'linear-gradient(135deg,#0a1628,#1a365d,#0e7490)',img:'https://picsum.photos/seed/civil1/1920/1080'},
    {bg:'linear-gradient(135deg,#1e1b4b,#312e81,#4338ca)',img:'https://picsum.photos/seed/arch1/1920/1080'},
    {bg:'linear-gradient(135deg,#0f1d35,#1e3a5f,#155e75)',img:'https://picsum.photos/seed/build1/1920/1080'},
    {bg:'linear-gradient(135deg,#0b1a2e,#1f4a6e,#0369a1)',img:'https://picsum.photos/seed/const1/1920/1080'},
    {bg:'linear-gradient(135deg,#1a0e2e,#3b1f6e,#6d28d9)',img:'https://picsum.photos/seed/bridge1/1920/1080'},
    {bg:'linear-gradient(135deg,#0b1f35,#065f46,#047857)',img:'https://picsum.photos/seed/road1/1920/1080'},
    {bg:'linear-gradient(135deg,#1c1917,#44403c,#57534e)',img:'https://picsum.photos/seed/tower1/1920/1080'},
    {bg:'linear-gradient(135deg,#0c0a09,#292524,#451a03)',img:'https://picsum.photos/seed/struct1/1920/1080'},
    {bg:'linear-gradient(135deg,#0f172a,#1e293b,#334155)',img:'https://picsum.photos/seed/engine1/1920/1080'},
    {bg:'linear-gradient(135deg,#020617,#0f172a,#1e293b)',img:'https://picsum.photos/seed/draw1/1920/1080'},
    {bg:'linear-gradient(135deg,#0a0e17,#111827,#1a2332)',img:'https://picsum.photos/seed/plan1/1920/1080'},
    {bg:'linear-gradient(135deg,#0f1d35,#1a3a5f,#1e4a7a)',img:'https://picsum.photos/seed/design1/1920/1080'},
    {bg:'linear-gradient(135deg,#0b1628,#1a365d,#0e7490)',img:'https://picsum.photos/seed/steel1/1920/1080'},
    {bg:'linear-gradient(135deg,#1a0e28,#2d1b69,#4c1d95)',img:'https://picsum.photos/seed/concr1/1920/1080'},
    {bg:'linear-gradient(135deg,#0b1a30,#1f4a6e,#0891b2)',img:'https://picsum.photos/seed/frame1/1920/1080'},
    {bg:'linear-gradient(135deg,#0c1f35,#065f46,#059669)',img:'https://picsum.photos/seed/crane1/1920/1080'},
    {bg:'linear-gradient(135deg,#1c1917,#57534e,#78716c)',img:'https://picsum.photos/seed/city1/1920/1080'},
    {bg:'linear-gradient(135deg,#0f172a,#1e293b,#475569)',img:'https://picsum.photos/seed/sky1/1920/1080'},
    {bg:'linear-gradient(135deg,#020617,#0f172a,#1e3a8a)',img:'https://picsum.photos/seed/modern1/1920/1080'},
    {bg:'linear-gradient(135deg,#0a0e17,#111827,#374151)',img:'https://picsum.photos/seed/glass1/1920/1080'},
    {bg:'linear-gradient(135deg,#0b1f35,#155e75,#0e7490)',img:'https://picsum.photos/seed/tunnel1/1920/1080'},
    {bg:'linear-gradient(135deg,#1a0e2e,#4c1d95,#7c3aed)',img:'https://picsum.photos/seed/pav1/1920/1080'},
    {bg:'linear-gradient(135deg,#0b1a2e,#0369a1,#0284c7)',img:'https://picsum.photos/seed/green1/1920/1080'},
    {bg:'linear-gradient(135deg,#0c0a09,#451a03,#92400e)',img:'https://picsum.photos/seed/found1/1920/1080'}
  ];
  var container = document.getElementById('heroSlider');
  var dotsContainer = document.getElementById('heroDots');
  var current = 0;
  var intervalId = null;

  function goToSlide(index) {
    var els = container.querySelectorAll('.hero-slide');
    var dots = dotsContainer.querySelectorAll('.dot');
    if (!els.length) return;
    if (els[current]) els[current].classList.remove('active');
    if (dots[current]) dots[current].classList.remove('active');
    current = index;
    if (els[current]) els[current].classList.add('active');
    if (dots[current]) dots[current].classList.add('active');
  }
  function nextSlide() { goToSlide((current + 1) % slides.length); }
  function start() { if (intervalId) clearInterval(intervalId); intervalId = setInterval(nextSlide, 5000); }
  function stop() { if (intervalId) { clearInterval(intervalId); intervalId = null; } }

  slides.forEach(function(item, i) {
    var div = document.createElement('div');
    div.className = 'hero-slide' + (i === 0 ? ' active' : '');
    div.style.background = item.bg;
    container.appendChild(div);
    var dot = document.createElement('span');
    dot.className = 'dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('role', 'button');
    dot.setAttribute('aria-label', 'Slide ' + (i + 1));
    dot.addEventListener('click', function() { stop(); goToSlide(i); start(); });
    dotsContainer.appendChild(dot);
    if (item.img) {
      var img = new Image();
      img.onload = function() { div.style.background = 'url(' + item.img + ') center/cover no-repeat'; };
      img.src = item.img;
    }
  });

  start();
  var hero = document.getElementById('home');
  if (hero) {
    hero.addEventListener('mouseenter', stop);
    hero.addEventListener('mouseleave', start);
  }
})();
</script>

<section class="section" style="background: linear-gradient(135deg, #0e7490 0%, #0891b2 100%);">
