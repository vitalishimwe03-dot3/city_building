<!-- Page Header -->
<section style="background-color: var(--bg-secondary); border-bottom: 1px solid var(--border-color);">
  <div class="container">
    <div style="text-align: center;">
      <h1 style="margin-bottom: var(--spacing-sm);">Get in Touch</h1>
      <p class="lead">We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
    </div>
  </div>
</section>

<!-- Main Content -->
<section>
  <div class="container">
    <div class="grid grid-2">
      <!-- Contact Form Column -->
      <div>
        <div class="form-wrapper">
          <form action="https://formspree.io/f/xqeozvnp" method="POST">
            <!-- Full Name Field -->
            <div class="form-group">
              <label class="form-label" for="contact-name">Full Name *</label>
              <input 
                id="contact-name" 
                name="name" 
                class="form-control" 
                placeholder="Your full name"
                required
                aria-required="true"
              >
            </div>

            <!-- Email Field -->
            <div class="form-group">
              <label class="form-label" for="contact-email">Email Address *</label>
              <input 
                type="email" 
                id="contact-email" 
                name="email" 
                class="form-control" 
                placeholder="your@email.com"
                required
                aria-required="true"
              >
            </div>

            <!-- Phone Field (Optional) -->
            <div class="form-group">
              <label class="form-label" for="contact-phone">Phone Number (Optional)</label>
              <input 
                type="tel" 
                id="contact-phone" 
                name="phone" 
                class="form-control" 
                placeholder="+1 (000) 000-0000"
              >
            </div>

            <!-- Subject Dropdown -->
            <div class="form-group">
              <label class="form-label" for="contact-subject" style="font-size: 30px; color: var(--color-primary);">Subject *</label>
              <select 
                id="contact-subject" 
                name="subject" 
                class="form-select" 
                required
                aria-required="true"
              >
                <option value="">Select a subject</option>
                <option value="course-inquiry">Course Inquiry</option>
                <option value="technical-support">Technical Support</option>
                <option value="partnership">Partnership Opportunity</option>
                <option value="feedback">Feedback</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Message Field -->
            <div class="form-group">
              <label class="form-label" for="contact-message">Message *</label>
              <textarea 
                id="contact-message" 
                name="message" 
                class="form-control" 
                placeholder="Your message here... (minimum 10 characters)"
                rows="5"
                minlength="10"
                required
                aria-required="true"
              ></textarea>
              <div class="form-help">Please provide details about your inquiry</div>
            </div>

            <!-- Checkbox: I agree to terms -->
            <div style="margin-bottom: var(--spacing-md); display: flex; gap: var(--spacing-sm);">
              <input 
                type="checkbox" 
                id="contact-agree" 
                name="agree_to_terms" 
                required
                aria-required="true"
              >
              <label for="contact-agree" style="font-size: var(--font-size-sm); cursor: pointer;">
                I agree to the privacy policy and terms of service
              </label>
            </div>

            <!-- Hidden Formspree Fields -->
            <input type="hidden" name="_subject" value="New contact request from City Building website">
            <input type="hidden" name="_captcha" value="false">

            <!-- Submit Button -->
            <button type="submit" class="btn btn-primary btn-lg" style="width: 100%;">
              <i class="bi bi-send"></i> Send Message
            </button>

            <!-- Privacy Notice -->
            <p style="font-size: var(--font-size-xs); color: var(--text-tertiary); margin-top: var(--spacing-md); text-align: center;">
              We'll get back to you within 24 hours during business days.
            </p>
          </form>
        </div>
      </div>

      <!-- Contact Information Column -->
      <div>
        <!-- Contact Info Card 1: Office -->
        <div class="card" style="margin-bottom: var(--spacing-lg);">
          <div class="card-body">
            <div style="display: flex; gap: var(--spacing-md); align-items: flex-start;">
              <div style="font-size: 1.75rem; color: var(--color-primary);">
                <i class="bi bi-geo-alt-fill"></i>
              </div>
              <div>
                <h3 class="h5" style="margin-bottom: var(--spacing-xs);">Head Office</h3>
                <address style="font-style: normal; color: var(--text-secondary); margin: 0;">
                  123 Engineering Street<br>
                  Technology Park<br>
                  City, Country 12345
                </address>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Info Card 2: Phone -->
        <div class="card" style="margin-bottom: var(--spacing-lg);">
          <div class="card-body">
            <div style="display: flex; gap: var(--spacing-md); align-items: flex-start;">
              <div style="font-size: 1.75rem; color: var(--color-primary);">
                <i class="bi bi-telephone-fill"></i>
              </div>
              <div>
                <h3 class="h5" style="margin-bottom: var(--spacing-xs);">Phone</h3>
                <p style="margin: 0; color: var(--text-secondary);">
                  <a href="tel:+1234567890" style="color: var(--color-primary); text-decoration: none;">
                    +1 (234) 567-890
                  </a>
                </p>
                <p style="margin: var(--spacing-xs) 0 0; font-size: var(--font-size-sm); color: var(--text-tertiary);">
                  Mon - Fri, 9 AM - 6 PM
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Info Card 3: Email -->
        <div class="card" style="margin-bottom: var(--spacing-lg);">
          <div class="card-body">
            <div style="display: flex; gap: var(--spacing-md); align-items: flex-start;">
              <div style="font-size: 1.75rem; color: var(--color-primary);">
                <i class="bi bi-envelope-fill"></i>
              </div>
              <div>
                <h3 class="h5" style="margin-bottom: var(--spacing-xs);">Email</h3>
                <p style="margin: 0; color: var(--text-secondary);">
                  <a href="mailto:info@citybuilding.com" style="color: var(--color-primary); text-decoration: none;">
                    info@citybuilding.com
                  </a>
                </p>
                <p style="margin: var(--spacing-xs) 0 0; font-size: var(--font-size-sm); color: var(--text-tertiary);">
                  We'll respond within 24 hours
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Contact Info Card 4: Hours -->
        <div class="card">
          <div class="card-body">
            <div style="display: flex; gap: var(--spacing-md); align-items: flex-start;">
              <div style="font-size: 1.75rem; color: var(--color-primary);">
                <i class="bi bi-clock-fill"></i>
              </div>
              <div>
                <h3 class="h5" style="margin-bottom: var(--spacing-xs);">Business Hours</h3>
                <ul style="list-style: none; padding: 0; margin: 0; font-size: var(--font-size-sm); color: var(--text-secondary);">
                  <li style="padding: var(--spacing-xs) 0;"><strong>Monday - Friday:</strong> 9:00 AM - 6:00 PM</li>
                  <li style="padding: var(--spacing-xs) 0;"><strong>Saturday:</strong> 10:00 AM - 4:00 PM</li>
                  <li style="padding: var(--spacing-xs) 0;"><strong>Sunday:</strong> Closed</li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Social Connections Section -->
<section style="background-color: var(--bg-secondary); text-align: center;">
  <div class="container">
    <h2 style="margin-bottom: var(--spacing-md);">Follow Us On Social Media</h2>
    <p class="lead" style="margin-bottom: var(--spacing-lg);">
      Stay updated with latest courses, industry news, and success stories
    </p>

    <div style="display: flex; justify-content: center; gap: var(--spacing-lg); flex-wrap: wrap;">
      <a 
        href="https://facebook.com/citybuilding" 
        class="btn" 
        style="background: #1877f2; color: white; width: auto;"
        aria-label="Follow us on Facebook"
      >
        <i class="bi bi-facebook"></i> Facebook
      </a>
      <a 
        href="https://twitter.com/citybuilding" 
        class="btn" 
        style="background: #000; color: white; width: auto;"
        aria-label="Follow us on Twitter"
      >
        <i class="bi bi-twitter-x"></i> Twitter
      </a>
      <a 
        href="https://linkedin.com/company/citybuilding" 
        class="btn" 
        style="background: #0a66c2; color: white; width: auto;"
        aria-label="Follow us on LinkedIn"
      >
        <i class="bi bi-linkedin"></i> LinkedIn
      </a>
      <a 
        href="https://www.instagram.com/city_building_engineering_cltd/" 
        class="btn" 
        style="background: #e1306c; color: white; width: auto;"
        aria-label="Follow us on Instagram"
      >
        <i class="bi bi-instagram"></i> Instagram
      </a>
      <a 
        href="https://youtube.com/@citybuilding" 
        class="btn" 
        style="background: #ff0000; color: white; width: auto;"
        aria-label="Subscribe on YouTube"
      >
        <i class="bi bi-youtube"></i> YouTube
      </a>
    </div>
  </div>
</section>

<!-- Map Section (Optional) -->
<section>
  <div class="container">
    <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">Visit Us</h2>
    <div style="border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-md); height: 400px; background-color: var(--bg-tertiary); display: flex; align-items: center; justify-content: center; color: var(--text-tertiary);">
      <!-- Embed your map here (Google Maps, Mapbox, etc.) -->
      <div style="text-align: center;">
        <i class="bi bi-map" style="font-size: 3rem; margin-bottom: var(--spacing-md);"></i>
        <p>Embed your location map here</p>
      </div>
    </div>
  </div>
</section>

<!-- FAQ Section -->
<section style="background-color: var(--bg-secondary);">
  <div class="container">
    <div style="max-width: 800px; margin: 0 auto;">
      <h2 style="text-align: center; margin-bottom: var(--spacing-lg);">Frequently Asked Questions</h2>

      <!-- FAQ Item 1 -->
      <div class="card" style="margin-bottom: var(--spacing-md);">
        <div class="card-body">
          <h3 class="h5" style="cursor: pointer; display: flex; justify-content: space-between; align-items: center;" onclick="this.parentElement.parentElement.querySelector('.faq-content').style.display = this.parentElement.parentElement.querySelector('.faq-content').style.display === 'none' ? 'block' : 'none';">
            How quickly will I receive a response? 
            <i class="bi bi-chevron-down"></i>
          </h3>
          <div class="faq-content" style="margin-top: var(--spacing-md); display: none; border-top: 1px solid var(--border-color); padding-top: var(--spacing-md);">
            <p style="color: var(--text-secondary); margin: 0;">We typically respond to all inquiries within 24 hours during business days. For urgent matters, please call us directly at +1 (234) 567-890.</p>
          </div>
        </div>
      </div>

      <!-- FAQ Item 2 -->
      <div class="card" style="margin-bottom: var(--spacing-md);">
        <div class="card-body">
          <h3 class="h5" style="cursor: pointer; display: flex; justify-content: space-between; align-items: center;" onclick="this.parentElement.parentElement.querySelector('.faq-content').style.display = this.parentElement.parentElement.querySelector('.faq-content').style.display === 'none' ? 'block' : 'none';">
            What are the course prerequisites?
            <i class="bi bi-chevron-down"></i>
          </h3>
          <div class="faq-content" style="margin-top: var(--spacing-md); display: none; border-top: 1px solid var(--border-color); padding-top: var(--spacing-md);">
            <p style="color: var(--text-secondary); margin: 0;">Most of our courses are designed for beginners, though some advanced courses require prior experience. Contact us to discuss which course is right for you.</p>
          </div>
        </div>
      </div>

      <!-- FAQ Item 3 -->
      <div class="card">
        <div class="card-body">
          <h3 class="h5" style="cursor: pointer; display: flex; justify-content: space-between; align-items: center;" onclick="this.parentElement.parentElement.querySelector('.faq-content').style.display = this.parentElement.parentElement.querySelector('.faq-content').style.display === 'none' ? 'block' : 'none';">
            Do you offer payment plans?
            <i class="bi bi-chevron-down"></i>
          </h3>
          <div class="faq-content" style="margin-top: var(--spacing-md); display: none; border-top: 1px solid var(--border-color); padding-top: var(--spacing-md);">
            <p style="color: var(--text-secondary); margin: 0;">Yes! We offer flexible payment plans for all our courses. Please contact our support team to discuss payment options that work best for you.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
