            <i class="bi bi-laptop fs-4" style="color: var(--accent-primary-light);"></i>
          </div>
          <h3 class="h5 fw-bold">Software Training</h3>
          <p class="small text-muted mb-0">Hands-on training in industry-standard engineering software including Revit, AutoCAD, ETABS, Civil 3D, Lumion, and more.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-4 rounded-4" style="background: var(--bg-surface); border: 1px solid var(--border-primary); height: 100%;">
          <div class="d-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; border-radius: 16px; background: rgba(8,145,178,0.12);">
            <i class="bi bi-briefcase fs-4" style="color: var(--accent-primary-light);"></i>
          </div>
          <h3 class="h5 fw-bold">Real Projects</h3>
          <p class="small text-muted mb-0">Work on actual engineering projects under professional supervision to build your portfolio and practical skills.</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="p-4 rounded-4" style="background: var(--bg-surface); border: 1px solid var(--border-primary); height: 100%;">
          <div class="d-flex align-items-center justify-content-center mb-3" style="width: 56px; height: 56px; border-radius: 16px; background: rgba(8,145,178,0.12);">
            <i class="bi bi-award fs-4" style="color: var(--accent-primary-light);"></i>
          </div>
          <h3 class="h5 fw-bold">Certification</h3>
          <p class="small text-muted mb-0">Earn a recognized certificate of internship completion from City Building Engineering Company Ltd.</p>
        </div>
      </div>
    </div>
  </div>
</section>

