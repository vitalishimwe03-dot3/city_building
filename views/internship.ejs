<%- include('partials/ads', { slot: 'topBanner' }) %>

<section class="py-5">
  <div class="container">
    <div class="row align-items-center g-5">
      <div class="col-lg-6">
        <p class="text-uppercase small fw-semibold mb-2" style="color: var(--accent-primary-light);">Internship Program</p>
