      <div class="col-lg-6">
        <img src="https://images.pexels.com/photos/3184418/pexels-photo-3184418.jpeg?auto=compress&cs=tinysrgb&w=800" alt="Engineering internship training at City Building Engineering in Kigali" class="img-fluid rounded-4 shadow-lg" style="width: 100%; max-width: 600px; object-fit: cover;">
      </div>
    </div>
  </div>
</section>

<section class="py-5" style="background: var(--bg-secondary);">
