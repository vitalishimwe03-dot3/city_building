<!doctype html>
<html lang="<%= language || 'en' %>">
  <head>
    <!-- Essential Meta Tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="City Building Engineering Company Ltd - Professional training in architectural, structural, and software design">
    <meta name="theme-color" content="#0f766e">
    
    <!-- Page Title -->
    <title><%= title || 'City Building - Professional Engineering Training' %></title>

    <!-- Bootstrap CSS (Foundation) -->
    <link 
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" 
      rel="stylesheet"
      integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" 
      crossorigin="anonymous"
    >
    
    <!-- Bootstrap Icons -->
    <link 
      rel="stylesheet" 
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css"
    >
    
    <!-- Modern Design System CSS -->
    <link rel="stylesheet" href="/css/design-system.css">
    <link rel="stylesheet" href="/css/components.css">
    
    <!-- Admin Dashboard Styles (if needed) -->
    <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
      <link rel="stylesheet" href="/css/admin-dashboard.css">
    <% } %>

    <!-- Preload Critical Resources -->
    <link rel="preload" href="/css/design-system.css" as="style">
    <link rel="preload" href="/css/components.css" as="style">
  </head>

  <body>
    <!-- Skip to Main Content (Accessibility) -->
    <a href="#main" class="btn btn-primary" style="position: absolute; top: -9999px;">Skip to main content</a>

    <!-- Navigation Bar -->
    <nav class="navbar navbar-expand-lg" role="navigation" aria-label="Main navigation">
      <div class="container">
        <!-- Brand Logo & Text -->
        <a class="navbar-brand" href="/" aria-label="City Building Engineering - Home">
          <img 
            src="/images/logo.svg" 
            alt="City Building Engineering Logo" 
            class="navbar-logo"
            width="200"
            height="48"
            loading="lazy"
          >
          <span class="navbar-brand-text d-none d-sm-inline">City Building</span>
        </a>

        <!-- Hamburger Toggle (Mobile) -->
        <button 
          class="navbar-toggler" 
          type="button" 
          data-bs-toggle="collapse" 
          data-bs-target="#mainNav" 
          aria-controls="mainNav" 
          aria-expanded="false" 
          aria-label="Toggle navigation"
        >
          <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navbar Collapse (Navigation Items) -->
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav ms-auto align-items-center">
            <!-- Home Link -->
            <li class="nav-item">
              <a class="nav-link" href="/">
                <i class="bi bi-house-door" aria-hidden="true"></i>
                <span><%- t('nav.home') %></span>
              </a>
            </li>

            <!-- About Link -->
            <li class="nav-item">
              <a class="nav-link" href="/about">
                <i class="bi bi-info-circle" aria-hidden="true"></i>
                <span><%- t('nav.about') %></span>
              </a>
            </li>

            <!-- Services Link -->
            <li class="nav-item">
              <a class="nav-link" href="/services">
                <i class="bi bi-briefcase" aria-hidden="true"></i>
                <span><%- t('nav.services') %></span>
              </a>
            </li>

            <!-- Contact Link -->
            <li class="nav-item">
              <a class="nav-link" href="/contact">
                <i class="bi bi-envelope" aria-hidden="true"></i>
                <span><%- t('nav.contact') %></span>
              </a>
            </li>

            <!-- Certificate Link -->
            <li class="nav-item">
              <a class="nav-link" href="/certificate">
                <i class="bi bi-award" aria-hidden="true"></i>
                <span><%- t('nav.certificate') %></span>
              </a>
            </li>

            <!-- Career Link -->
            <li class="nav-item">
              <a class="nav-link" href="/career">
                <i class="bi bi-briefcase" aria-hidden="true"></i>
                <span><%- t('nav.career') %></span>
              </a>
            </li>

            <!-- Divider (Mobile Only) -->
            <li class="nav-item d-lg-none my-2">
              <hr class="dropdown-divider">
            </li>

            <!-- User Authentication Dropdown -->
            <% if (siteUser) { %>
              <li class="nav-item dropdown">
                <a 
                  class="nav-link dropdown-toggle" 
                  href="#" 
                  id="userDropdown" 
                  role="button" 
                  data-bs-toggle="dropdown" 
                  aria-expanded="false"
                >
                  <i class="bi bi-person-circle" aria-hidden="true"></i>
                  <span class="d-lg-inline"><%= siteUser.full_name || siteUser.email %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                  <li>
                    <a class="dropdown-item" href="/account">
                      <i class="bi bi-person" aria-hidden="true"></i> <%- t('nav.account') %>
                    </a>
                  </li>
                  <li><hr class="dropdown-divider"></li>
                  <li>
                    <a class="dropdown-item text-danger" href="/logout">
                      <i class="bi bi-box-arrow-right" aria-hidden="true"></i> <%- t('nav.logout') %>
                    </a>
                  </li>
                </ul>
              </li>
            <% } else { %>
              <!-- Login Link -->
              <li class="nav-item">
                <a class="nav-link" href="/login">
                  <i class="bi bi-box-arrow-in-right" aria-hidden="true"></i>
                  <span><%- t('nav.login') %></span>
                </a>
              </li>

              <!-- Signup Link -->
              <li class="nav-item">
                <a class="nav-link" href="/signup">
                  <i class="bi bi-person-plus" aria-hidden="true"></i>
                  <span><%- t('nav.signup') %></span>
                </a>
              </li>
            <% } %>

            <!-- Language Selector (if multiple languages supported) -->
            <% if (typeof currentLanguage !== 'undefined') { %>
              <li class="nav-item dropdown d-none d-md-block">
                <button 
                  class="nav-link dropdown-toggle" 
                  id="languageDropdown" 
                  data-bs-toggle="dropdown" 
                  aria-expanded="false"
                  aria-label="Select language"
                >
                  <i class="bi bi-globe" aria-hidden="true"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="languageDropdown">
                  <li><a class="dropdown-item" href="/set-language/en">English</a></li>
                  <li><a class="dropdown-item" href="/set-language/es">Español</a></li>
                  <li><a class="dropdown-item" href="/set-language/fr">Français</a></li>
                  <li><a class="dropdown-item" href="/set-language/de">Deutsch</a></li>
                </ul>
              </li>
            <% } %>

          </ul>
        </div>
      </div>
    </nav>

    <!-- Main Content Area -->
    <main id="main" role="main">
      <!-- Flash Messages (Success, Error, Info) -->
      <% if (typeof messages !== 'undefined') { %>
        <% if (messages.success) { %>
          <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle" aria-hidden="true"></i>
            <div>
              <strong><%= messages.success.title || 'Success' %></strong>
              <p><%= messages.success.message %></p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>

        <% if (messages.error) { %>
          <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle" aria-hidden="true"></i>
            <div>
              <strong><%= messages.error.title || 'Error' %></strong>
              <p><%= messages.error.message %></p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>

        <% if (messages.info) { %>
          <div class="alert alert-info alert-dismissible fade show" role="alert">
            <i class="bi bi-info-circle" aria-hidden="true"></i>
            <div>
              <strong><%= messages.info.title || 'Information' %></strong>
              <p><%= messages.info.message %></p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
          </div>
        <% } %>
      <% } %>

      <!-- Page Content -->
      <%- body %>
    </main>

    <!-- Footer -->
    <footer class="footer" role="contentinfo">
      <div class="container">
        <div class="grid grid-4">
          <!-- Company Info -->
          <div class="footer-section">
            <h3 class="footer-title">Company</h3>
            <ul class="list-unstyled">
              <li><a href="/about" class="footer-link">About Us</a></li>
              <li><a href="/" class="footer-link">Home</a></li>
              <li><a href="/services" class="footer-link">Services</a></li>
              <li><a href="/contact" class="footer-link">Contact</a></li>
            </ul>
          </div>

          <!-- Learning -->
          <div class="footer-section">
            <h3 class="footer-title">Learning</h3>
            <ul class="list-unstyled">
              <li><a href="/certificate" class="footer-link">Certificates</a></li>
              <li><a href="/career" class="footer-link">Career</a></li>
              <li><a href="#courses" class="footer-link">Courses</a></li>
              <li><a href="/contact" class="footer-link">Enquiries</a></li>
            </ul>
          </div>

          <!-- Support -->
          <div class="footer-section">
            <h3 class="footer-title">Support</h3>
            <ul class="list-unstyled">
              <li><a href="#faq" class="footer-link">FAQ</a></li>
              <li><a href="/contact" class="footer-link">Help Center</a></li>
              <li><a href="#" class="footer-link">Documentation</a></li>
              <li><a href="#" class="footer-link">Feedback</a></li>
            </ul>
          </div>

          <!-- Contact Info -->
          <div class="footer-section">
            <h3 class="footer-title">Contact</h3>
            <ul class="list-unstyled">
              <li><a href="tel:+1234567890" class="footer-link">📞 +1 (234) 567-890</a></li>
              <li><a href="mailto:info@citybuilding.com" class="footer-link">📧 info@citybuilding.com</a></li>
              <li><address class="footer-link" style="font-style: normal;">
                123 Engineering Street<br>
                City, Country 12345
              </address></li>
            </ul>
          </div>
        </div>

        <!-- Footer Bottom -->
        <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: var(--spacing-lg); margin-top: var(--spacing-2xl);">
          <div class="grid grid-2">
            <div class="text-center text-md-start">
              <p style="margin: 0; opacity: 0.8;">
                &copy; 2024 City Building Engineering Company Ltd. All rights reserved.
              </p>
            </div>
            <div class="text-center text-md-end">
              <ul style="list-style: none; display: flex; gap: var(--spacing-md); justify-content: center;">
                <li><a href="#privacy" class="footer-link">Privacy Policy</a></li>
                <li><a href="#terms" class="footer-link">Terms of Service</a></li>
                <li><a href="#cookies" class="footer-link">Cookie Policy</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <!-- Bootstrap JS Bundle (Includes Popper) -->
    <script 
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-C6RzsynM9uju7jY0CKl9BQm78P4OvVJQj6UtlIOYnlIC7kPCheP/DnMr6qoBeXeS" 
      crossorigin="anonymous"
    ></script>

    <!-- Site.js (Global functionality) -->
    <script src="/js/site.js" defer></script>
  </body>
</html>

