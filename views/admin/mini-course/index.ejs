<div class="d-flex justify-content-between align-items-center mb-4">
  <div><h4 style="margin:0;font-weight:700;"><i class="bi bi-envelope-open"></i> Mini-Course Signups</h4><small style="color:var(--text-muted);">Students who signed up for the free 7-day mini course</small></div>
</div>
<div class="admin-card-modern">
  <% if (!signups || signups.length === 0) { %>
    <div class="empty-state"><i class="bi bi-envelope-open"></i><h5>No signups yet</h5><p>The free mini-course lead magnet has no signups yet.</p></div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table-custom">
        <thead><tr><th>Name</th><th>Email</th><th>Phone</th><th>Interest</th><th>Lesson 1</th><th>Lesson 2</th><th>Lesson 3</th><th>Date</th><th>Actions</th></tr></thead>
        <tbody>
          <% signups.forEach(function(s) { %>
            <tr>
              <td><strong><%= s.name %></strong></td>
              <td><%= s.email %></td>
              <td><%= s.phone || '-' %></td>
              <td><small><%= s.course_interest || '-' %></small></td>
              <td><span class="badge-custom <%= s.sent_lesson_1 ? 'success' : 'secondary' %>"><%= s.sent_lesson_1 ? 'Sent' : '-' %></span></td>
              <td><span class="badge-custom <%= s.sent_lesson_2 ? 'success' : 'secondary' %>"><%= s.sent_lesson_2 ? 'Sent' : '-' %></span></td>
              <td><span class="badge-custom <%= s.sent_lesson_3 ? 'success' : 'secondary' %>"><%= s.sent_lesson_3 ? 'Sent' : '-' %></span></td>
              <td><small><%= new Date(s.created_at).toLocaleDateString() %></small></td>
              <td>
                <div class="action-btns" style="flex-wrap: nowrap;">
                  <% if (!s.sent_lesson_1) { %><form action="/admin/mini-course/<%= s.id %>/lesson" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="lesson" value="1"><button type="submit" class="btn btn-sm-custom btn-edit-custom" title="Mark Lesson 1 Sent">L1</button></form><% } %>
                  <% if (s.sent_lesson_1 && !s.sent_lesson_2) { %><form action="/admin/mini-course/<%= s.id %>/lesson" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="lesson" value="2"><button type="submit" class="btn btn-sm-custom btn-edit-custom" title="Mark Lesson 2 Sent">L2</button></form><% } %>
                  <% if (s.sent_lesson_2 && !s.sent_lesson_3) { %><form action="/admin/mini-course/<%= s.id %>/lesson" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><input type="hidden" name="lesson" value="3"><button type="submit" class="btn btn-sm-custom btn-edit-custom" title="Mark Lesson 3 Sent">L3</button></form><% } %>
                  <form action="/admin/mini-course/<%= s.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this signup?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm-custom btn-delete-custom"><i class="bi bi-trash"></i></button></form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
