<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Admin Reset Password' %> - City Building Engineering</title>
  <meta name="robots" content="noindex, nofollow">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-icon" style="background: linear-gradient(135deg, #0891b2, #06b6d4);"><i class="bi bi-shield-lock"></i></div>
      <div class="logo-text">Set new password</div>
      <div class="logo-sub">Must be 8+ characters with a symbol</div>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="auth-error"><i class="bi bi-shield-exclamation"></i> <%= error %></div>
    <% } %>

    <form method="POST" action="/admin/reset-password" id="resetForm">
      <input type="hidden" name="token" value="<%= typeof token !== 'undefined' ? token : '' %>">
      <div class="form-floating-group">
        <input type="password" id="password" name="password" class="form-control" placeholder="New password" required pattern="^(?=.*[a-z])(?=.*[A-Z])(?=.*\d)(?=.*[!@#$%^&*()_+\-=\[\]{};':\"\\|,.<>\/?]).{8,}$" autocomplete="new-password">
        <label for="password">New password</label>
        <button type="button" class="password-toggle" id="pwToggle" tabindex="-1"><i class="bi bi-eye-slash"></i></button>
        <div class="pw-strength" id="pwStrength"><span class="pw-bar"></span><span class="pw-bar"></span><span class="pw-bar"></span><span class="pw-bar"></span></div>
        <div class="pw-strength-text" id="pwStrengthText"></div>
        <div class="invalid-feedback">8+ chars, uppercase, lowercase, number & symbol required.</div>
      </div>
      <div class="form-floating-group">
        <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Confirm password" required autocomplete="new-password">
        <label for="confirmPassword">Confirm password</label>
        <div class="invalid-feedback">Passwords must match.</div>
      </div>
      <button type="submit" class="btn btn-primary w-100"><i class="bi bi-check-circle"></i> Reset Password</button>
    </form>

    <div class="auth-footer">
      <a href="/admin/login">Back to login</a>
    </div>
  </div>
  <script>
  document.addEventListener('DOMContentLoaded', function() {
    var pwInput = document.getElementById('password');
    var pwBtn = document.getElementById('pwToggle');
    if (pwBtn) {
      pwBtn.addEventListener('click', function() {
        var type = pwInput.type === 'password' ? 'text' : 'password';
        pwInput.type = type;
        pwBtn.querySelector('i').className = type === 'password' ? 'bi bi-eye-slash' : 'bi bi-eye';
      });
    }
    var strength = document.getElementById('pwStrength');
    var strengthText = document.getElementById('pwStrengthText');
    if (pwInput) {
      pwInput.addEventListener('input', function() {
        var val = pwInput.value;
        var bars = strength.querySelectorAll('.pw-bar');
        bars.forEach(function(b) { b.className = 'pw-bar'; });
        if (!val) { strengthText.textContent = ''; return; }
        var score = 0;
        if (val.length >= 8) score++;
        if (/[a-z]/.test(val)) score++;
        if (/[A-Z]/.test(val)) score++;
        if (/\d/.test(val)) score++;
        if (/[^a-zA-Z0-9]/.test(val)) score++;
        var label = '', cls = '';
        if (score <= 2) { label = 'Weak'; cls = 'weak'; for (var i = 0; i < 1 && i < bars.length; i++) bars[i].className += ' ' + cls; }
        else if (score <= 3) { label = 'Medium'; cls = 'medium'; for (var i = 0; i < 2 && i < bars.length; i++) bars[i].className += ' ' + cls; }
        else if (score <= 4) { label = 'Strong'; cls = 'strong'; for (var i = 0; i < 3 && i < bars.length; i++) bars[i].className += ' ' + cls; }
        else { label = 'Very strong'; cls = 'very-strong'; for (var i = 0; i < 4 && i < bars.length; i++) bars[i].className += ' ' + cls; }
        strengthText.textContent = label;
        strengthText.className = 'pw-strength-text ' + cls;
      });
    }
    var form = document.getElementById('resetForm');
    form.addEventListener('submit', function(e) {
      if (form.password.value !== form.confirmPassword.value) {
        form.confirmPassword.setCustomValidity('Passwords do not match');
        e.preventDefault();
      } else {
        form.confirmPassword.setCustomValidity('');
      }
      if (!form.checkValidity()) { e.preventDefault(); e.stopPropagation(); }
      form.classList.add('was-validated');
    });
  });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
