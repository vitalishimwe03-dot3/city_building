<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="margin:0;font-weight:700;"><i class="bi bi-bookmarks"></i> Categories</h4>
        <small style="color:var(--text-muted);">Manage course categories</small>
    </div>
    <a href="/admin/categories/create" class="btn btn-sm-custom btn-edit-custom"><i class="bi bi-plus-circle"></i> Add Category</a>
</div>

<div class="admin-card-modern">
    <% if (categories.length === 0) { %>
        <div class="empty-state"><i class="bi bi-bookmarks"></i><h5>No categories found</h5></div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr><th>Name</th><th>Slug</th><th>Description</th><th>Created</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    <% categories.forEach(category => { %>
                        <tr>
                            <td><strong><%= category.name %></strong></td>
                            <td><code><%= category.slug %></code></td>
                            <td><small><%= category.description || '(No description)' %></small></td>
                            <td><small><%= new Date(category.created_at).toLocaleDateString() %></small></td>
                            <td>
                                <div class="action-btns">
                                    <a href="/admin/categories/<%= category.id %>/edit" class="btn btn-sm-custom btn-edit-custom"><i class="bi bi-pencil"></i></a>
                                    <form action="/admin/categories/<%= category.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete category?')">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="btn btn-sm-custom btn-delete-custom"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
