<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="margin:0;font-weight:700;"><i class="bi bi-mortarboard"></i> Courses</h4>
        <small style="color:var(--text-muted);">Manage training courses</small>
    </div>
    <a href="/admin/courses/create" class="btn btn-sm-custom btn-edit-custom"><i class="bi bi-plus-circle"></i> Add Course</a>
</div>

<div class="admin-card-modern">
    <% if (courses.length === 0) { %>
        <div class="empty-state"><i class="bi bi-mortarboard"></i><h5>No courses found</h5></div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr><th>Course Name</th><th>Category</th><th>Slug</th><th>Image</th><th>Created</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    <% courses.forEach(course => { %>
                        <tr>
                            <td><strong><%= course.name %></strong></td>
                            <td><%= course.category_name %></td>
                            <td><code><%= course.slug %></code></td>
                            <td><small><%= course.image ? 'Has image' : 'No image' %></small></td>
                            <td><small><%= new Date(course.created_at).toLocaleDateString() %></small></td>
                            <td>
                                <div class="action-btns">
                                    <a href="/admin/courses/<%= course.id %>/edit" class="btn btn-sm-custom btn-edit-custom"><i class="bi bi-pencil"></i></a>
                                    <form action="/admin/courses/<%= course.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete course?')">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="btn btn-sm-custom btn-delete-custom"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
