<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="margin:0;font-weight:700;"><i class="bi bi-envelope"></i> Enquiries</h4>
        <small style="color:var(--text-muted);">Manage contact form submissions</small>
    </div>
</div>

<div class="admin-card-modern">
    <% if (enquiries.length === 0) { %>
        <div class="empty-state"><i class="bi bi-inbox"></i><h5>No enquiries yet</h5></div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr><th>Name</th><th>Email</th><th>Phone</th><th>Status</th><th>Date</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    <% enquiries.forEach(enquiry => { %>
                        <tr>
                            <td><strong><%= enquiry.name %></strong></td>
                            <td><%= enquiry.email %></td>
                            <td><small><%= enquiry.phone %></small></td>
                            <td>
                                <span class="badge badge-custom <%= enquiry.status === 'new' ? 'warning' : (enquiry.status === 'contacted' ? 'info' : 'secondary') %>">
                                    <%= enquiry.status %>
                                </span>
                            </td>
                            <td><small><%= new Date(enquiry.created_at).toLocaleDateString() %></small></td>
                            <td>
                                <div class="action-btns">
                                    <a href="/admin/enquiries/<%= enquiry.id %>" class="btn btn-sm-custom btn-view-custom"><i class="bi bi-eye"></i></a>
                                    <form action="/admin/enquiries/<%= enquiry.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete enquiry?')">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                        <button type="submit" class="btn btn-sm-custom btn-delete-custom"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
