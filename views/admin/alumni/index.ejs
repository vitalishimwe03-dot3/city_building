<div class="d-flex justify-content-between align-items-center mb-4">
  <div><h4 style="margin:0;font-weight:700;"><i class="bi bi-people"></i> Alumni Directory</h4><small style="color:var(--text-muted);">Manage alumni profiles displayed on the alumni page</small></div>
  <a href="/admin/alumni/create" class="btn btn-sm-custom btn-edit-custom"><i class="bi bi-plus-circle"></i> Add Alumni</a>
</div>
<div class="admin-card-modern">
  <% if (!alumni || alumni.length === 0) { %>
    <div class="empty-state"><i class="bi bi-people"></i><h5>No alumni yet</h5><p>Add alumni profiles to showcase graduate success.</p></div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table-custom">
        <thead><tr><th>Name</th><th>Employer</th><th>Location</th><th>Course</th><th>Status</th><th>Actions</th></tr></thead>
        <tbody>
          <% alumni.forEach(function(a) { %>
            <tr>
              <td><strong><%= a.student_name %></strong><br><small class="text-muted"><%= a.job_title || '' %></small></td>
              <td><%= a.employer || '-' %></td>
              <td><%= a.city || a.location || 'Kigali' %></td>
              <td><small><%= a.course_name || '-' %></small></td>
              <td><span class="badge-custom <%= a.is_active ? 'success' : 'secondary' %>"><%= a.is_active ? 'Active' : 'Inactive' %></span><% if (a.is_featured) { %> <span class="badge-custom warning">Featured</span><% } %></td>
              <td>
                <div class="action-btns">
                  <a href="/admin/alumni/<%= a.id %>/edit" class="btn btn-sm-custom btn-edit-custom"><i class="bi bi-pencil"></i></a>
                  <form action="/admin/alumni/<%= a.id %>/toggle" method="POST" style="display:inline;"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm-custom btn-toggle-custom"><i class="bi <%= a.is_active ? 'bi-eye-slash' : 'bi-eye' %>"></i></button></form>
                  <form action="/admin/alumni/<%= a.id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('Delete this alumni?')"><input type="hidden" name="_csrf" value="<%= csrfToken %>"><button type="submit" class="btn btn-sm-custom btn-delete-custom"><i class="bi bi-trash"></i></button></form>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
