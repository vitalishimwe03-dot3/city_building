<div class="row mb-4"><div class="col-md-8"><h3><%= alum ? 'Edit Alumni' : 'Add New Alumni' %></h3></div></div>
<div class="admin-card-modern" style="max-width: 750px;">
  <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
  <form method="POST" action="<%= alum ? '/admin/alumni/' + alum.id : '/admin/alumni' %>">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label">Student Name *</label>
        <input type="text" class="form-control" name="student_name" value="<%= alum?.student_name || '' %>" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">Course Taken</label>
        <input type="text" class="form-control" name="course_name" value="<%= alum?.course_name || '' %>">
      </div>
    </div>
    <div class="row mb-3">
      <div class="col-md-6">
        <label class="form-label">Employer</label>
        <input type="text" class="form-control" name="employer" value="<%= alum?.employer || '' %>">
      </div>
      <div class="col-md-6">
        <label class="form-label">Job Title</label>
        <input type="text" class="form-control" name="job_title" value="<%= alum?.job_title || '' %>">
      </div>
    </div>
    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label">City</label>
        <input type="text" class="form-control" name="city" value="<%= alum?.city || 'Kigali' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Country</label>
        <input type="text" class="form-control" name="country" value="<%= alum?.country || 'Rwanda' %>">
      </div>
      <div class="col-md-4">
        <label class="form-label">Location (full)</label>
        <input type="text" class="form-control" name="location" value="<%= alum?.location || '' %>">
      </div>
    </div>
    <div class="mb-3">
      <label class="form-label">LinkedIn URL</label>
      <input type="url" class="form-control" name="linkedin_url" value="<%= alum?.linkedin_url || '' %>">
    </div>
    <div class="mb-3">
      <label class="form-label">Testimonial</label>
      <textarea class="form-control" name="testimonial" rows="3"><%= alum?.testimonial || '' %></textarea>
    </div>
    <div class="row mb-3">
      <div class="col-md-4">
        <label class="form-label">Sort Order</label>
        <input type="number" class="form-control" name="sort_order" value="<%= alum?.sort_order || 0 %>">
      </div>
      <div class="col-md-4 d-flex align-items-end">
        <div class="form-check"><input type="checkbox" class="form-check-input" id="is_featured" name="is_featured" <%= (alum?.is_featured) ? 'checked' : '' %>><label class="form-check-label" for="is_featured">Featured</label></div>
      </div>
      <div class="col-md-4 d-flex align-items-end">
        <div class="form-check"><input type="checkbox" class="form-check-input" id="is_active" name="is_active" <%= (!alum || alum.is_active) ? 'checked' : '' %>><label class="form-check-label" for="is_active">Active</label></div>
      </div>
    </div>
    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-sm-custom btn-edit-custom"><i class="bi bi-check-circle"></i> <%= alum ? 'Update' : 'Create' %> Alumni</button>
      <a href="/admin/alumni" class="btn btn-sm-custom btn-view-custom"><i class="bi bi-x"></i> Cancel</a>
    </div>
  </form>
</div>
