<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Admin Check Email' %> - City Building Engineering</title>
  <meta name="robots" content="noindex, nofollow">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-icon" style="background: linear-gradient(135deg, #0891b2, #06b6d4); width: 72px; height: 72px; border-radius: 50%;"><i class="bi bi-envelope-check" style="font-size: 30px;"></i></div>
    </div>
    <h2>Check your email</h2>
    <p class="auth-subtitle"><%= typeof message !== 'undefined' ? message : 'A password reset link has been sent.' %></p>
    <div style="background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px 18px; text-align: center; margin: 16px 0;">
      <span style="font-weight: 700; color: var(--accent); font-size: 15px;"><%= typeof email !== 'undefined' ? email : '' %></span>
    </div>
    <p style="text-align: center; font-size: 13px; color: var(--text-muted);">The link expires in 24 hours. Check spam if not received.</p>
    <a href="/login" class="btn btn-primary w-100"><i class="bi bi-arrow-left"></i> Back to Login</a>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
