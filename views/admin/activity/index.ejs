<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h4 style="margin:0;font-weight:700;"><i class="bi bi-activity"></i> Activity Log</h4>
    <small style="color:var(--text-muted);">Track all admin actions</small>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="admin-card-modern">
      <div class="card-header-custom">
        <h5><i class="bi bi-list-stars" style="color:#0891b2;"></i> Recent Actions</h5>
      </div>
      <% if (logs.length === 0) { %>
        <div class="empty-state"><i class="bi bi-clock-history"></i><h5>No activity logged yet</h5><p>Actions will appear here as you use the admin panel.</p></div>
      <% } else { %>
        <ul class="activity-feed">
          <% logs.forEach(function(log) { %>
            <li>
              <div class="activity-icon" style="background:rgba(8,145,178,0.1);color:#0891b2;">
                <i class="bi bi-circle-fill" style="font-size:8px;"></i>
              </div>
              <div class="activity-content">
                <div class="activity-text">
                  <strong><%= log.admin_name %></strong> <%= log.action %>
                  <% if (log.details) { %><br><small style="color:var(--text-muted);font-size:11px;"><%= log.details %></small><% } %>
                </div>
                <div class="activity-time"><%= new Date(log.created_at).toLocaleString() %></div>
              </div>
            </li>
          <% }); %>
        </ul>
      <% } %>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="admin-card-modern">
      <div class="card-header-custom">
        <h5><i class="bi bi-pie-chart" style="color:#0891b2;"></i> Activity Breakdown</h5>
      </div>
      <% if (stats.length > 0) { %>
        <div style="margin-bottom:16px;">
          <% stats.forEach(function(s) { %>
            <div style="display:flex;align-items:center;justify-content:space-between;padding:8px 0;border-bottom:1px solid var(--border-light);">
              <span style="font-size:13px;color:var(--text-primary);"><%= s.action %></span>
              <span class="badge badge-custom primary"><%= s.count %></span>
            </div>
          <% }); %>
        </div>
      <% } else { %>
        <div class="empty-state"><i class="bi bi-pie-chart"></i><h5>No stats yet</h5></div>
      <% } %>
    </div>
  </div>
</div>
