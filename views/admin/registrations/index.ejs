<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 style="margin:0;font-weight:700;"><i class="bi bi-journal-bookmark-fill"></i> Course Registrations</h4>
        <small style="color:var(--text-muted);">Manage student course enrollments</small>
    </div>
</div>

<div class="admin-card-modern">
    <% if (registrations.length === 0) { %>
        <div class="empty-state"><i class="bi bi-journal-text"></i><h5>No registrations yet</h5></div>
    <% } else { %>
        <div class="table-responsive">
            <table class="table-custom">
                <thead>
                    <tr><th>Student</th><th>Email</th><th>Course</th><th>Category</th><th>Status</th><th>Date</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    <% registrations.forEach(reg => { %>
                        <tr>
                            <td><strong><%= reg.user_name %></strong></td>
                            <td><%= reg.user_email %></td>
                            <td><%= reg.course_name %></td>
                            <td><small><%= reg.category_name %></small></td>
                            <td>
                                <span class="badge badge-custom <%= reg.status === 'approved' ? 'success' : (reg.status === 'pending' ? 'warning' : 'danger') %>">
                                    <%= reg.status %>
                                </span>
                            </td>
                            <td><small><%= new Date(reg.created_at).toLocaleDateString() %></small></td>
                            <td>
                                <form action="/admin/registrations/<%= reg.id %>/status" method="POST" style="display:inline;">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <select name="status" class="form-select form-select-sm d-inline-block" style="width:auto;font-size:12px;padding:4px 8px;" onchange="this.form.submit()">
                                        <option value="pending" <%= reg.status === 'pending' ? 'selected' : '' %>>Pending</option>
                                        <option value="approved" <%= reg.status === 'approved' ? 'selected' : '' %>>Approved</option>
                                        <option value="rejected" <%= reg.status === 'rejected' ? 'selected' : '' %>>Rejected</option>
                                    </select>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</div>
