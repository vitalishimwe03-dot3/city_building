<%- include('../admin-layout', { body: `
<div class="container">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-cloud-upload me-2"></i>Upload Images</h4>
    <a href="/admin/images" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i> Back to Gallery</a>
  </div>
  <div class="admin-card-modern">
    <form action="/admin/images/upload" method="POST" enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label fw-semibold">Select Images</label>
        <input type="file" name="image" class="form-control" accept=".jpg,.jpeg,.png,.webp" required style="background:var(--bg-surface);border:1px solid var(--border-primary);color:var(--text-primary);">
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Section</label>
        <select name="section" class="form-select" style="background:var(--bg-surface);border:1px solid var(--border-primary);color:var(--text-primary);">
          <% sections.forEach(s => { %>
            <option value="<%= s.value %>"><%= s.label %></option>
          <% }) %>
        </select>
      </div>
      <div class="mb-3">
        <label class="form-label fw-semibold">Alt Text</label>
        <input type="text" name="alt_text" class="form-control" placeholder="Describe this image..." style="background:var(--bg-surface);border:1px solid var(--border-primary);color:var(--text-primary);">
      </div>
      <button type="submit" class="btn btn-primary"><i class="bi bi-upload me-1"></i> Upload</button>
    </form>
  </div>
</div>
` }) %>
