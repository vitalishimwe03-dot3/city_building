<!-- CTA Section -->
<section style="background: linear-gradient(135deg, var(--color-primary), var(--color-primary-light)); color: white; text-align: center;">
  <div class="container">
    <h2 style="color: white; margin-bottom: var(--spacing-md);">Ready to Transform Your Career?</h2>
    <p class="lead" style="color: rgba(255,255,255,0.9); margin-bottom: var(--spacing-xl);">
      Join thousands of professionals who have advanced their careers with our courses
    </p>
    <button 
      class="btn btn-lg" 
      style="background: white; color: var(--color-primary); font-weight: var(--font-weight-semibold);"
      onclick="document.getElementById('apply-form').scrollIntoView({behavior: 'smooth'})"
    >
      <i class="bi bi-arrow-up"></i> Apply Now
    </button>
  </div>
</section>
