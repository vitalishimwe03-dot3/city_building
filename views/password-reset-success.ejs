<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'Password Reset Successful' %> - City Building Engineering</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body class="auth-page">
  <div class="auth-card">
    <div class="auth-brand">
      <div class="auth-icon" style="background: linear-gradient(135deg, #10b981, #34d399); width: 72px; height: 72px; border-radius: 50%;"><i class="bi bi-check-lg" style="font-size: 30px;"></i></div>
    </div>
    <h2>Password reset successful</h2>
    <p class="auth-subtitle"><%= typeof message !== 'undefined' ? message : 'Your password has been changed successfully.' %></p>
    <a href="/login" class="btn btn-primary w-100"><i class="bi bi-box-arrow-in-right"></i> Sign In Now</a>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
