<section class="py-5">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-xl-10">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-start gap-3 mb-4">
          <div>
            <h2 class="h3 mb-1">Account Dashboard</h2>
            <p class="text-muted mb-0">Welcome back, <strong><%= user.full_name %></strong>. Track your courses and manage your profile.</p>
          </div>
          <div class="text-md-end">
            <span class="badge bg-primary">Member since <%= new Date(user.created_at).toLocaleDateString() %></span>
          </div>
        </div>

        <div class="card shadow-sm">
          <div class="card-body p-4">
            <% if (error) { %>
              <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <% if (success) { %>
              <div class="alert alert-success alert-dismissible fade show" role="alert">
                ✅ <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
              </div>
            <% } %>

            <ul class="nav nav-tabs mb-4" id="settingsTabs" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" id="dashboard-tab" data-bs-toggle="tab" data-bs-target="#dashboard" type="button" role="tab">Dashboard</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="courses-tab" data-bs-toggle="tab" data-bs-target="#courses" type="button" role="tab">My Courses</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab">Profile</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="password-tab" data-bs-toggle="tab" data-bs-target="#password" type="button" role="tab">Password</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="wishlist-tab" data-bs-toggle="tab" data-bs-target="#wishlist" type="button" role="tab">Wishlist</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" id="language-tab" data-bs-toggle="tab" data-bs-target="#language" type="button" role="tab">Language</button>
              </li>
            </ul>

            <div class="tab-content" id="settingsTabsContent">
              <div class="tab-pane fade show active" id="dashboard" role="tabpanel" aria-labelledby="dashboard-tab">
                <div class="row g-3 mb-4">
                  <div class="col-lg-6">
                    <div class="card h-100 border-primary">
                      <div class="card-body">
                        <h5 class="card-title">Welcome back!</h5>
                        <p class="card-text">Your account is active and ready. Use the tabs to update your profile, secure your password, or choose your preferred language.</p>
                      </div>
                    </div>
                  </div>
                  <div class="col-lg-6">
                    <div class="card h-100 border-secondary">
                      <div class="card-body">
                        <h5 class="card-title">Account summary</h5>
                        <p class="mb-1"><strong>Email:</strong> <%= user.email %></p>
                        <p class="mb-1"><strong>Phone:</strong> <%= user.phone || 'Not set' %></p>
                        <p class="mb-0"><strong>Language:</strong> <%= user.language || 'en' %></p>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="row g-3" id="progressOverview">
                  <div class="col-12">
                    <h5 class="fw-bold mb-3"><i class="bi bi-graph-up"></i> Learning Progress</h5>
                  </div>
                  <div class="col-12 text-center py-4 text-muted" id="progressLoading">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div> Loading your progress...
                  </div>
                </div>

                <div class="row g-3 mt-2">
                  <% if (dashboardNews && dashboardNews.length) { %>
                    <% dashboardNews.forEach(item => { %>
                      <div class="col-md-6">
                        <div class="card h-100">
                          <div class="card-body">
                            <h5 class="card-title"><%= item.title %></h5>
                            <p class="card-text"><%= item.summary %></p>
                            <p class="text-muted small mb-0"><%= item.date %></p>
                          </div>
                        </div>
                      </div>
                    <% }) %>
                  <% } else { %>
                    <div class="col-12">
                      <div class="card">
                        <div class="card-body">
                          <p class="mb-0">No dashboard news available right now.</p>
                        </div>
                      </div>
                    </div>
                  <% } %>
                </div>
              </div>

              <div class="tab-pane fade" id="courses" role="tabpanel" aria-labelledby="courses-tab">
                <div id="coursesContainer">
                  <div class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div> Loading your courses...
                  </div>
                </div>
              </div>

              <div class="tab-pane fade" id="profile" role="tabpanel" aria-labelledby="profile-tab">
                <form method="post" action="/account/profile" class="row g-3">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <div class="col-md-6">
                    <label class="form-label">Full Name</label>
                    <input type="text" name="fullName" class="form-control" value="<%= user.full_name %>" required>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-control" value="<%= user.email %>" required readonly>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label">Phone</label>
                    <div class="phone-group">
                      <div class="flag-select" id="profileFlagSelect">
                        <div class="flag-trigger" id="profileFlagTrigger">
                          <span class="flag-emoji" id="profileFlagEmoji">🇷🇼</span>
                          <span class="flag-code" id="profileFlagCode">+250</span>
                        </div>
                        <div class="flag-dropdown" id="profileFlagDropdown"></div>
                        <select name="countryCode" id="profileCountryCode" style="display:none">
                          <option value="+250" data-flag="🇷🇼" data-name="Rwanda">+250</option>
                          <option value="+256" data-flag="🇺🇬" data-name="Uganda">+256</option>
                          <option value="+254" data-flag="🇰🇪" data-name="Kenya">+254</option>
                          <option value="+255" data-flag="🇹🇿" data-name="Tanzania">+255</option>
                          <option value="+257" data-flag="🇧🇮" data-name="Burundi">+257</option>
                          <option value="+243" data-flag="🇨🇩" data-name="DRC">+243</option>
                          <option value="+27" data-flag="🇿🇦" data-name="South Africa">+27</option>
                          <option value="+234" data-flag="🇳🇬" data-name="Nigeria">+234</option>
                          <option value="+233" data-flag="🇬🇭" data-name="Ghana">+233</option>
                          <option value="+251" data-flag="🇪🇹" data-name="Ethiopia">+251</option>
                          <option value="+20" data-flag="🇪🇬" data-name="Egypt">+20</option>
                          <option value="+212" data-flag="🇲🇦" data-name="Morocco">+212</option>
                          <option value="+225" data-flag="🇨🇮" data-name="Côte d'Ivoire">+225</option>
                          <option value="+237" data-flag="🇨🇲" data-name="Cameroon">+237</option>
                          <option value="+211" data-flag="🇸🇸" data-name="South Sudan">+211</option>
                          <option value="+1" data-flag="🇺🇸" data-name="USA">+1</option>
                          <option value="+44" data-flag="🇬🇧" data-name="UK">+44</option>
                          <option value="+33" data-flag="🇫🇷" data-name="France">+33</option>
                          <option value="+49" data-flag="🇩🇪" data-name="Germany">+49</option>
                          <option value="+86" data-flag="🇨🇳" data-name="China">+86</option>
                          <option value="+91" data-flag="🇮🇳" data-name="India">+91</option>
                          <option value="+971" data-flag="🇦🇪" data-name="UAE">+971</option>
                          <option value="+966" data-flag="🇸🇦" data-name="Saudi Arabia">+966</option>
                          <option value="+81" data-flag="🇯🇵" data-name="Japan">+81</option>
                        </select>
                      </div>
                      <input type="tel" name="phone" class="form-control phone-input" id="profilePhone" value="<%= user.phone ? user.phone.replace(/^\+\d+\s*/,'') : '' %>" placeholder="Phone number">
                    </div>
                    <script>
                      (function() {
                        var select = document.getElementById('profileCountryCode');
                        var input = document.getElementById('profilePhone');
                        var trigger = document.getElementById('profileFlagTrigger');
                        var dropdown = document.getElementById('profileFlagDropdown');
                        var emoji = document.getElementById('profileFlagEmoji');
                        var code = document.getElementById('profileFlagCode');

                        function buildList() {
                          dropdown.innerHTML = '';
                          for (var i = 0; i < select.options.length; i++) {
                            var opt = select.options[i];
                            var div = document.createElement('div');
                            div.className = 'flag-option' + (opt.selected ? ' active' : '');
                            div.innerHTML = '<span class="flag-emoji">' + (opt.getAttribute('data-flag') || '') + '</span><span class="flag-label">' + (opt.getAttribute('data-name') || '') + '</span><span class="flag-dial">' + opt.value + '</span>';
                            div.dataset.value = opt.value;
                            div.dataset.flag = opt.getAttribute('data-flag') || '';
                            div.addEventListener('click', function() {
                              select.value = this.dataset.value;
                              emoji.textContent = this.dataset.flag;
                              code.textContent = this.dataset.value;
                              if (dropdown) dropdown.classList.remove('open');
                              var all = dropdown.querySelectorAll('.flag-option');
                              for (var j = 0; j < all.length; j++) all[j].classList.remove('active');
                              this.classList.add('active');
                            });
                            dropdown.appendChild(div);
                          }
                        }

                        if (select && input && dropdown && emoji && code) {
                          buildList();

                          var full = '<%= user.phone || "" %>';
                          var match = full.match(/^(\+\d+)\s*(.*)/);
                          if (match) {
                            for (var i = 0; i < select.options.length; i++) {
                              if (select.options[i].value === match[1]) {
                                select.selectedIndex = i;
                                emoji.textContent = select.options[i].getAttribute('data-flag') || '';
                                code.textContent = match[1];
                                break;
                              }
                            }
                            input.value = match[2];
                          }

                          input.addEventListener('input', function() {
                            this.value = this.value.replace(/[^0-9\s\-\(\)]/g, '');
                          });

                          trigger.addEventListener('click', function(e) {
                            e.stopPropagation();
                            dropdown.classList.toggle('open');
                          });

                          document.addEventListener('click', function() {
                            dropdown.classList.remove('open');
                          });

                          var form = select.closest('form');
                          if (form) {
                            form.addEventListener('submit', function() {
                              input.value = select.value + ' ' + input.value.replace(/^\+?\d+\s*/, '');
                            });
                          }
                        }
                      })();
                    </script>
                  </div>
                  <div class="col-12">
                    <button type="submit" class="btn btn-primary">Update Profile</button>
                  </div>
                </form>
              </div>

              <div class="tab-pane fade" id="password" role="tabpanel" aria-labelledby="password-tab">
                <form method="post" action="/account/change-password" class="row g-3">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <div class="col-12">
                    <label class="form-label">Current Password</label>
                    <input type="password" name="currentPassword" class="form-control" required>
                  </div>
                  <div class="col-12">
                    <label class="form-label">New Password</label>
                    <input type="password" name="newPassword" class="form-control" required>
                  </div>
                  <div class="col-12">
                    <label class="form-label">Confirm New Password</label>
                    <input type="password" name="confirmPassword" class="form-control" required>
                  </div>
                  <div class="col-12">
                    <button type="submit" class="btn btn-primary">Change Password</button>
                  </div>
                </form>
              </div>

              <div class="tab-pane fade" id="wishlist" role="tabpanel" aria-labelledby="wishlist-tab">
                <div id="wishlistContainer">
                  <div class="text-center py-4 text-muted">
                    <div class="spinner-border spinner-border-sm me-2" role="status"></div> Loading your wishlist...
                  </div>
                </div>
              </div>

              <div class="tab-pane fade" id="language" role="tabpanel" aria-labelledby="language-tab">
                <form method="post" action="/account/language" class="row g-3">
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <div class="col-md-6">
                    <label class="form-label">Preferred language</label>
                    <select name="language" class="form-select">
                      <option value="en" <%= user.language === 'en' ? 'selected' : '' %>>English</option>
                      <option value="fr" <%= user.language === 'fr' ? 'selected' : '' %>>Français</option>
                      <option value="es" <%= user.language === 'es' ? 'selected' : '' %>>Español</option>
                      <option value="pt" <%= user.language === 'pt' ? 'selected' : '' %>>Português</option>
                      <option value="ar" <%= user.language === 'ar' ? 'selected' : '' %>>العربية</option>
                      <option value="sw" <%= user.language === 'sw' ? 'selected' : '' %>>Kiswahili</option>
                      <option value="de" <%= user.language === 'de' ? 'selected' : '' %>>Deutsch</option>
                      <option value="zh" <%= user.language === 'zh' ? 'selected' : '' %>>中文</option>
                      <option value="ru" <%= user.language === 'ru' ? 'selected' : '' %>>Русский</option>
                      <option value="it" <%= user.language === 'it' ? 'selected' : '' %>>Italiano</option>
                      <option value="tr" <%= user.language === 'tr' ? 'selected' : '' %>>Türkçe</option>
                      <option value="am" <%= user.language === 'am' ? 'selected' : '' %>>አማርኛ</option>
                      <option value="th" <%= user.language === 'th' ? 'selected' : '' %>>ไทย</option>
                      <option value="fa" <%= user.language === 'fa' ? 'selected' : '' %>>فارسی</option>
                    </select>
                  </div>
                  <div class="col-12">
                    <button type="submit" class="btn btn-primary">Save Language</button>
                  </div>
                </form>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.progress-card { background: var(--bg-card); border: 1px solid var(--border-primary); border-radius: 12px; padding: 20px; transition: transform 0.2s, box-shadow 0.2s; }
.progress-card:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
.progress-card .course-title { font-size: 16px; font-weight: 700; margin-bottom: 4px; }
.progress-card .course-category { font-size: 12px; color: var(--text-muted); margin-bottom: 12px; }
.progress-card .progress-wrap { height: 8px; background: var(--bg-surface); border-radius: 4px; overflow: hidden; margin-bottom: 8px; }
.progress-card .progress-wrap .progress-fill { height: 100%; border-radius: 4px; background: linear-gradient(90deg, #0891b2, #06b6d4); transition: width 0.6s ease; }
.progress-card .progress-stats { display: flex; justify-content: space-between; font-size: 13px; color: var(--text-secondary); }
.module-item { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 8px; background: var(--bg-surface); margin-bottom: 6px; transition: background 0.2s; }
.module-item:hover { background: var(--bg-elevated); }
.module-item .module-check { width: 22px; height: 22px; border-radius: 50%; border: 2px solid var(--text-muted); display: flex; align-items: center; justify-content: center; cursor: pointer; transition: all 0.2s; flex-shrink: 0; }
.module-item .module-check.done { background: #10b981; border-color: #10b981; color: #fff; }
.module-item .module-check:hover { border-color: #0891b2; }
.module-item .module-title { flex: 1; font-size: 14px; font-weight: 500; }
.module-item .module-order { font-size: 11px; color: var(--text-muted); }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  loadProgress();
  loadCourses();

  document.getElementById('courses-tab')?.addEventListener('shown.bs.tab', function() { loadCourses(); });
  document.getElementById('dashboard-tab')?.addEventListener('shown.bs.tab', function() { loadProgress(); });
  document.getElementById('wishlist-tab')?.addEventListener('shown.bs.tab', function() { loadWishlist(); });
});

async function loadProgress() {
  const container = document.getElementById('progressOverview');
  const loading = document.getElementById('progressLoading');
  if (!container) return;
  try {
    const res = await fetch('/api/my-progress');
    const courses = await res.json();
    if (loading) loading.style.display = 'none';

    const existingCards = container.querySelectorAll('.progress-card-wrap');
    existingCards.forEach(el => el.remove());

    if (!courses || courses.length === 0) {
      container.insertAdjacentHTML('beforeend', '<div class="col-12 progress-card-wrap"><div class="card"><div class="card-body text-center text-muted py-4"><i class="bi bi-book" style="font-size:32px;display:block;margin-bottom:8px;opacity:0.4;"></i>You are not enrolled in any courses yet. <a href="/">Browse courses</a> to get started!</div></div></div>');
      return;
    }

    courses.forEach(c => {
      const pct = c.total_modules > 0 ? Math.round((c.completed_modules / c.total_modules) * 100) : 0;
      const badge = pct === 100 ? '<span class="badge bg-success">Completed</span>' : (pct > 0 ? '<span class="badge bg-info">In Progress</span>' : '<span class="badge bg-secondary">Not Started</span>');
      var certLink = '';
      if (pct === 100) {
        certLink = '<div class="mt-2"><a href="/api/course/' + c.subcourse_id + '/certificate" class="btn btn-sm btn-success" target="_blank"><i class="bi bi-award-fill"></i> Certificate</a></div>';
      }
      container.insertAdjacentHTML('beforeend',
        '<div class="col-md-6 progress-card-wrap">' +
          '<div class="progress-card">' +
            '<div class="course-title">' + escHtml(c.course_name) + '</div>' +
            '<div class="course-category">' + escHtml(c.category_name) + ' — ' + badge + '</div>' +
            '<div class="progress-wrap"><div class="progress-fill" style="width:' + pct + '%"></div></div>' +
            '<div class="progress-stats"><span>' + c.completed_modules + '/' + c.total_modules + ' modules</span><span>' + pct + '%</span></div>' +
            certLink +
          '</div>' +
        '</div>'
      );
    });
  } catch (e) {
    console.error('Failed to load progress:', e);
    if (loading) loading.style.display = 'none';
  }
}

async function loadCourses() {
  const container = document.getElementById('coursesContainer');
  if (!container) return;
  try {
    const res = await fetch('/api/my-registrations');
    const registrations = await res.json();
    if (!registrations || registrations.length === 0) {
      container.innerHTML = '<div class="text-center py-4 text-muted"><i class="bi bi-journal-plus" style="font-size:48px;display:block;margin-bottom:12px;opacity:0.3;"></i><p>You are not enrolled in any courses yet.</p><a href="/" class="btn btn-primary">Browse Courses</a></div>';
      return;
    }
    let html = '';
    for (const reg of registrations) {
      const modRes = await fetch('/api/course/' + reg.subcourse_id + '/modules');
      const modules = await modRes.json();
      const total = modules.length;
      const done = modules.filter(m => m.completed).length;
      const pct = total > 0 ? Math.round((done / total) * 100) : 0;
      const statusBadge = pct === 100 ? 'bg-success' : (pct > 0 ? 'bg-info' : 'bg-secondary');
      const statusText = pct === 100 ? 'Completed' : (pct > 0 ? 'In Progress' : 'Not Started');

      var certHtml = '';
      if (pct === 100) {
        certHtml = '<div class="mt-2"><a href="/api/course/' + reg.subcourse_id + '/certificate" class="btn btn-sm btn-success" target="_blank"><i class="bi bi-award-fill"></i> Download Certificate</a></div>';
      }
      html += '<div class="card mb-3">' +
        '<div class="card-body">' +
          '<div class="d-flex justify-content-between align-items-start mb-2">' +
            '<div>' +
              '<h5 class="mb-1">' + escHtml(reg.course_name) + '</h5>' +
              '<small class="text-muted">' + escHtml(reg.category_name) + ' — <span class="badge ' + statusBadge + '">' + statusText + '</span></small>' +
            '</div>' +
            '<div class="text-end">' +
              '<div class="fw-bold fs-5" style="color:var(--accent);">' + pct + '%</div>' +
              '<small class="text-muted">' + done + '/' + total + '</small>' +
            '</div>' +
          '</div>' +
          '<div class="progress mb-3" style="height:6px;"><div class="progress-bar" style="width:' + pct + '%;background:linear-gradient(90deg,#0891b2,#06b6d4);"></div></div>' +
          certHtml +
          '<div class="modules-list">';

      modules.forEach(m => {
        const checked = m.completed ? 'done' : '';
        const icon = m.completed ? 'bi-check-lg' : 'bi-circle';
        html += '<div class="module-item" data-module-id="' + m.id + '" data-course-id="' + reg.subcourse_id + '" data-completed="' + m.completed + '">' +
          '<div class="module-check ' + checked + '"><i class="bi ' + icon + '" style="font-size:12px;"></i></div>' +
          '<span class="module-order">Module ' + m.order_index + '</span>' +
          '<span class="module-title">' + escHtml(m.title) + '</span>' +
          (m.completed ? '<small class="text-success"><i class="bi bi-check-circle"></i> Done</small>' : '') +
        '</div>';
      });

      html += '</div></div></div>';
    }
    container.innerHTML = html;

    container.querySelectorAll('.module-check').forEach(el => {
      el.addEventListener('click', async function() {
        const moduleId = this.closest('.module-item').dataset.moduleId;
        const courseId = this.closest('.module-item').dataset.courseId;
        const isCompleted = this.closest('.module-item').dataset.completed === '1';
        const url = isCompleted
          ? '/api/course/' + courseId + '/module/' + moduleId + '/uncomplete'
          : '/api/course/' + courseId + '/module/' + moduleId + '/complete';
        try {
          const res = await fetch(url, { method: 'POST' });
          const data = await res.json();
          if (data.success) {
            loadCourses();
            loadProgress();
          }
        } catch (e) {
          console.error('Failed to update module:', e);
        }
      });
    });
  } catch (e) {
    console.error('Failed to load courses:', e);
    container.innerHTML = '<div class="alert alert-danger">Failed to load your courses. Please try again later.</div>';
  }
}

async function loadWishlist() {
  var container = document.getElementById('wishlistContainer');
  if (!container) return;
  try {
    var res = await fetch('/api/my-wishlist');
    var items = await res.json();
    if (!items || items.length === 0) {
      container.innerHTML = '<div class="text-center py-4 text-muted"><i class="bi bi-bookmark-heart" style="font-size:48px;display:block;margin-bottom:12px;opacity:0.3;"></i><p>Your wishlist is empty.</p><a href="/" class="btn btn-primary">Browse Courses</a></div>';
      return;
    }
    var html = '<div class="row g-3">';
    items.forEach(function(item) {
      var stars = '';
      var avg = parseFloat(item.avg_rating) || 0;
      for (var i = 1; i <= 5; i++) {
        stars += '<i class="bi ' + (i <= Math.round(avg) ? 'bi-star-fill' : 'bi-star') + '" style="color:#f59e0b;font-size:0.8rem;"></i>';
      }
      html += '<div class="col-md-6">' +
        '<div class="card h-100">' +
          '<div class="card-body">' +
            '<h5 class="card-title">' + escHtml(item.course_name) + '</h5>' +
            '<p class="text-muted small mb-2">' + escHtml(item.category_name) + ' &middot; ' + stars + ' <span class="ms-1">' + (avg > 0 ? avg.toFixed(1) : 'No ratings') + '</span></p>' +
            '<p class="card-text small text-muted">' + escHtml((item.course_desc || '').substring(0, 120)) + '</p>' +
            '<a href="/course/' + item.subcourse_id + '" class="btn btn-sm btn-outline-primary">View Course <i class="bi bi-arrow-right"></i></a>' +
          '</div>' +
        '</div>' +
      '</div>';
    });
    html += '</div>';
    container.innerHTML = html;
  } catch (e) {
    console.error('Failed to load wishlist:', e);
    container.innerHTML = '<div class="alert alert-danger">Failed to load wishlist.</div>';
  }
}

function escHtml(str) {
  if (!str) return '';
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}
</script>
