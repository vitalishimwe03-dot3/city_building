      "description": "Enroll in professional software training courses in Kigali, Rwanda. Learn Revit, AutoCAD, ETABS, Lumion and more at City Building Engineering Company Ltd.",
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "<%= reqProtocol || 'https' %>://<%= reqHost || 'citybuilding.rw' %>/?search={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }
    </script>
    <% if (typeof breadcrumbs !== 'undefined' && breadcrumbs && breadcrumbs.length > 0) { %>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        <% breadcrumbs.forEach(function(crumb, i) { %>
        {
          "@type": "ListItem",
          "position": <%= i + 1 %>,
          "name": "<%= crumb.name %>",
          "item": "<%= crumb.url %>"
        }<%= i < breadcrumbs.length - 1 ? ',' : '' %>
        <% }) %>
      ]
    }
    </script>
