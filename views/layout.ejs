<!doctype html>
<html lang="<%= currentLanguage || 'en' %>">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title><%= title || 'City Building Engineering - Professional Software Training in Kigali, Rwanda' %></title>
    <meta name="description" content="<%= typeof metaDescription !== 'undefined' && metaDescription !== null ? metaDescription : 'City Building Engineering Company Ltd offers professional software training in Revit, AutoCAD, ETABS, Lumion and more. Enroll in Kigali, Rwanda for career-ready engineering and design courses.' %>">
    <meta name="keywords" content="city building engineering, software training Kigali, Revit course Rwanda, AutoCAD training, ETABS course, engineering courses Rwanda, professional training, BIM training, structural software, rendering courses">
    <meta name="author" content="City Building Engineering Company Ltd">
    <meta name="robots" content="index, follow">
    <link rel="canonical" href="<%= typeof canonicalUrl !== 'undefined' && canonicalUrl ? canonicalUrl : 'https://citybuilding.rw' %>">
    <meta property="og:type" content="website">
    <meta property="og:title" content="<%= title || 'City Building Engineering - Professional Software Training' %>">
    <meta property="og:description" content="Professional software training for architecture, engineering, design, and construction careers in Kigali, Rwanda.">
    <meta property="og:image" content="/images/logo.png">
    <meta property="og:url" content="<%= canonicalUrl || 'https://citybuilding.rw' %>">
    <meta property="og:locale" content="en_RW">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="City Building Engineering - Professional Software Training">
    <meta name="twitter:description" content="Professional software training for architecture, engineering, design, and construction careers in Kigali, Rwanda.">
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "City Building Engineering Company Ltd",
      "url": "https://citybuilding.rw",
      "logo": "/images/logo.png",
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+250-789-257-758",
        "contactType": "enrollment",
        "availableLanguage": ["English", "French", "Kinyarwanda"]
      },
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Kigali",
        "addressCountry": "RW"
      }
    }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="icon" type="image/png" href="/images/logo.png">
    <link rel="apple-touch-icon" href="/images/logo.png">
    <link rel="shortcut icon" href="/images/logo.png">
    <script>(function(){var t=localStorage.getItem('citybuilding-theme');if(!t){t=window.matchMedia('(prefers-color-scheme:light)').matches?'light':'dark'}document.documentElement.setAttribute('data-theme',t)})();</script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/admin-dashboard.css">
  </head>
  <body>
    <% if (isAdminAuthenticated) { %>
    <div class="admin-toolbar">
      <div class="container-fluid px-2 px-lg-4 d-flex align-items-center justify-content-between">
        <div class="d-flex align-items-center gap-3">
          <i class="bi bi-shield-lock-fill"></i>
          <strong>Admin Panel</strong>
          <a href="/admin/dashboard" class="text-white-50 text-decoration-none small">Dashboard</a>
          <a href="/admin/enquiries" class="text-white-50 text-decoration-none small">Enquiries</a>
          <a href="/admin/registrations" class="text-white-50 text-decoration-none small">Registrations</a>
          <a href="/admin/users" class="text-white-50 text-decoration-none small">Users</a>
          <a href="/admin/categories" class="text-white-50 text-decoration-none small">Categories</a>
          <a href="/admin/courses" class="text-white-50 text-decoration-none small">Courses</a>
          <a href="/admin/settings" class="text-white-50 text-decoration-none small">Settings</a>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="small"><%= adminUser?.full_name || adminUser?.username %></span>
          <a href="/admin/logout" class="btn btn-sm btn-outline-light"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </div>
      </div>
    </div>
    <% } %>
    <nav class="navbar navbar-expand-lg sticky-top" id="mainNavbar">
      <div class="container-fluid px-3 px-lg-4 navbar-inner">
        <a class="navbar-brand d-flex align-items-center gap-2" href="/" aria-label="City Building Engineering Company Ltd">
          <img src="/images/logo.png" srcset="/images/logo.png 1x" alt="City Building Engineering Logo" class="navbar-logo" loading="eager" decoding="sync" onerror="this.style.display='none'; this.nextElementSibling.classList.remove('d-none');">
          <span class="navbar-brand-text d-none">
            <span class="brand-main">City Building</span>
            <span class="brand-sub">ENGINEERING COMPANY LTD</span>
          </span>
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav ms-auto align-items-center gap-1 gap-lg-2">
            <li class="nav-item">
              <a class="nav-link px-2 px-lg-3" href="/">
                <i class="bi bi-house-door"></i>
                <span class="d-inline"><%- t('nav.home') %></span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link px-2 px-lg-3" href="/about">
                <i class="bi bi-info-circle"></i>
                <span class="d-inline"><%- t('nav.about') %></span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link px-2 px-lg-3" href="/services">
                <i class="bi bi-briefcase"></i>
                <span class="d-inline"><%- t('nav.services') %></span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link px-2 px-lg-3" href="/contact">
                <i class="bi bi-envelope"></i>
                <span class="d-inline"><%- t('nav.contact') %></span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link px-2 px-lg-3" href="/certificate">
                <i class="bi bi-award"></i>
                <span class="d-inline"><%- t('nav.certificate') %></span>
              </a>
            </li>
            <li class="nav-item">
              <a class="nav-link px-2 px-lg-3" href="/career">
                <i class="bi bi-briefcase"></i>
                <span class="d-inline"><%- t('nav.career') %></span>
              </a>
            </li>
            <li class="nav-item d-lg-none my-2">
              <hr class="dropdown-divider">
            </li>
            <% if (siteUser) { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle px-2 px-lg-3" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="bi bi-person-circle"></i>
                  <span class="d-lg-inline"><%= siteUser.full_name || siteUser.email %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                  <li><a class="dropdown-item" href="/account"><i class="bi bi-person"></i> <%- t('nav.account') %></a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="dropdown-item text-danger" href="/logout"><i class="bi bi-box-arrow-right"></i> <%- t('nav.logout') %></a></li>
                </ul>
              </li>
            <% } else { %>
              <li class="nav-item">
                <a class="nav-link px-2 px-lg-3" href="/login">
                  <i class="bi bi-box-arrow-in-right"></i>
                  <span class="d-lg-inline"><%- t('nav.login') %></span>
                </a>
              </li>
              <li class="nav-item">
                <a class="nav-link px-2 px-lg-3" href="/signup">
                  <i class="bi bi-person-plus"></i>
                  <span class="d-lg-inline"><%- t('nav.signup') %></span>
                </a>
              </li>
            <% } %>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle px-2 px-lg-3" href="#" id="langDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-globe"></i>
                <span id="currentLang" class="d-lg-inline"><%= currentLanguage.toUpperCase() %></span>
              </a>
              <ul class="dropdown-menu dropdown-menu-end lang-dropdown-menu" aria-labelledby="langDropdown">
                <% supportedLanguages.forEach(lang => { %>
                  <li>
                    <a class="dropdown-item <%= lang === currentLanguage ? 'active' : '' %>" href="?lang=<%= lang %>">
                      <i class="bi <%= lang === currentLanguage ? 'bi-check' : '' %>"></i>
                      <%= ({en:'English',fr:'Français',es:'Español',pt:'Português',ar:'العربية',sw:'Kiswahili',de:'Deutsch',zh:'中文',ru:'Русский',it:'Italiano',tr:'Türkçe',am:'አማርኛ'})[lang] || lang.toUpperCase() %>
                    </a>
                  </li>
                <% }); %>
              </ul>
            </li>
            <li class="nav-item d-flex align-items-center">
              <button id="themeToggle" class="theme-toggle" type="button" aria-label="Toggle theme">
                <i class="bi bi-sun-fill"></i>
              </button>
            </li>
          </ul>
        </div>
      </div>
    </nav>

    <main>
      <%- body %>
    </main>

    <footer class="site-footer">
      <div class="container py-5">
        <div class="row g-4 align-items-start">
          <div class="col-12 col-sm-6 col-lg-4">
            <div class="d-flex align-items-center gap-2 mb-3">
              <span class="logo-badge footer-badge">
                <img src="/images/logo.png" srcset="/images/logo.png 1x" alt="City Building Engineering Logo" class="footer-logo" loading="lazy" decoding="async">
              </span>
              <div>
                <h2 class="h6 mb-0">City Building Engineering Company Ltd</h2>
                <p class="small text-light-emphasis mb-0">Engineering training hub</p>
              </div>
            </div>
            <div class="mb-3">
              <label for="language-select" class="form-label small fw-bold"><%- t('account.language') %>:</label>
              <select id="language-select" class="form-select form-select-sm">
                <% supportedLanguages.forEach(lang => { %>
                  <option value="<%= lang %>" <%= lang === currentLanguage ? 'selected' : '' %>><%= languageNames[lang] || lang.toUpperCase() %></option>
                <% }); %>
              </select>
            </div>
            <p class="mb-2 small"><i class="bi bi-envelope-fill me-2"></i> citybuildingengineeringcompany@gmail.com</p>
            <p class="mb-2 small"><i class="bi bi-telephone-fill me-2"></i> +250 789 257 758</p>
            <p class="small text-light-emphasis">Professional software training for architecture, engineering, design, and construction careers.</p>
          </div>
          <div class="col-6 col-sm-3 col-lg-2">
            <h3 class="h6 text-uppercase fw-bold mb-3">Explore</h3>
            <ul class="list-unstyled footer-links small">
              <li><a href="/">Home</a></li>
              <li><a href="/about">About Us</a></li>
              <li><a href="/services">Services</a></li>
              <li><a href="/certificate">Certificate</a></li>
            </ul>
          </div>
          <div class="col-6 col-sm-3 col-lg-2">
            <h3 class="h6 text-uppercase fw-bold mb-3">Quick Links</h3>
            <ul class="list-unstyled footer-links small">
              <li><a href="/career">Career</a></li>
              <li><a href="/signup">Join Us</a></li>
              <li><a href="/contact">Contact Us</a></li>
              <li><a href="/login">Login</a></li>
            </ul>
          </div>
          <div class="col-12 col-lg-3">
            <h3 class="h6 text-uppercase fw-bold mb-3">Connect</h3>
            <div class="d-flex flex-wrap gap-2 mb-3">
              <a class="social-chip" href="https://wa.me/250789257758" target="_blank" rel="noreferrer" title="Chat on WhatsApp">
                <i class="bi bi-whatsapp"></i>
                <span class="d-none d-sm-inline">WhatsApp</span>
              </a>
              <a class="social-chip" href="https://facebook.com" target="_blank" rel="noreferrer" title="Follow on Facebook">
                <i class="bi bi-facebook"></i>
                <span class="d-none d-sm-inline">Facebook</span>
              </a>
              <a class="social-chip" href="https://www.instagram.com/city_building_engineering_cltd/" target="_blank" rel="noreferrer" title="Follow on Instagram">
                <i class="bi bi-instagram"></i>
                <span class="d-none d-sm-inline">Instagram</span>
              </a>
              <a class="social-chip" href="https://linkedin.com" target="_blank" rel="noreferrer" title="Follow on LinkedIn">
                <i class="bi bi-linkedin"></i>
                <span class="d-none d-sm-inline">LinkedIn</span>
              </a>
              <a class="social-chip" href="https://youtube.com" target="_blank" rel="noreferrer" title="Subscribe on YouTube">
                <i class="bi bi-youtube"></i>
                <span class="d-none d-sm-inline">YouTube</span>
              </a>
            </div>
            <p class="small mb-0 text-light-emphasis">
              Chat on WhatsApp: <a class="text-white text-decoration-none fw-semibold" href="https://wa.me/250789257758?text=Hello%20City%20Building!%20I%27m%20interested%20in%20your%20software%20training%20courses.">+250 789 257 758</a>
            </p>
          </div>
        </div>
        <div class="border-top mt-4 pt-4" style="border-color: var(--border-primary) !important;">
          <div class="row g-2 align-items-center">
            <div class="col-12 col-md-6">
              <small class="text-light-emphasis">© City Building Engineering Company Ltd — May 2026 intake</small>
            </div>
            <div class="col-12 col-md-6 text-md-end">
              <small class="text-light-emphasis">Professional software training for architecture, engineering, design, and construction careers.</small>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <a href="https://wa.me/250789257758?text=Hello%20City%20Building!%20I%27m%20interested%20in%20your%20software%20training%20courses." target="_blank" rel="noreferrer" class="whatsapp-float" title="Chat on WhatsApp">
      <i class="bi bi-whatsapp"></i>
      <span class="whatsapp-float-text">Chat with us</span>
    </a>

    <div id="ai-chat-toggle" class="ai-chat-fab" title="AI Assistant">
      <i class="bi bi-robot"></i>
    </div>

    <div id="ai-chat-panel" class="ai-chat-panel">
      <div class="ai-chat-header">
        <i class="bi bi-robot"></i> AI Course Assistant
        <button id="ai-chat-close" class="btn-close btn-close-white float-end"></button>
      </div>
      <div class="ai-chat-messages" id="ai-chat-messages">
        <div class="ai-message ai-bot">
          <strong>AI Assistant</strong><br>
          Hello! I can help you find the right software training course. Ask me anything about our programs, pricing, or enrollment.
        </div>
      </div>
      <div class="ai-chat-input">
        <input type="text" id="ai-chat-input" class="form-control form-control-sm" placeholder="Ask me about courses...">
        <button id="ai-chat-send" class="btn btn-primary btn-sm"><i class="bi bi-send"></i></button>
      </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/@formspree/ajax@1" defer></script>
    <script src="/js/theme.js"></script>
    <script src="/js/site.js" defer></script>
    <script src="/js/ai-assistant.js" defer></script>
    <script>
    document.addEventListener('DOMContentLoaded', function() {
      var langSelect = document.getElementById('language-select');
      if (langSelect) {
        langSelect.addEventListener('change', function() {
          var url = new URL(window.location.href);
          url.searchParams.set('lang', this.value);
          window.location.href = url.toString();
        });
      }
    });
    </script>
  </body>
</html>
