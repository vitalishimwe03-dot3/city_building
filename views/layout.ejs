    <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Smart language persistence
      var langSelect = document.getElementById('language-select');
      if (langSelect) {
        langSelect.addEventListener('change', function() {
          var lang = this.value;
          document.cookie = 'citybuilding_lang=' + lang + '; path=/; max-age=' + (365 * 24 * 60 * 60) + '; SameSite=Lax';
          var url = new URL(window.location.href);
          url.searchParams.set('lang', lang);
          window.location.href = url.toString();
        });
      }
      // Restore language from cookie if no lang param in URL
      var urlParams = new URLSearchParams(window.location.search);
      if (!urlParams.has('lang')) {
        var cookies = document.cookie.split(';');
        for (var i = 0; i < cookies.length; i++) {
          var parts = cookies[i].trim().split('=');
          if (parts[0] === 'citybuilding_lang' && parts[1] && parts[1] !== '<%= currentLanguage %>') {
            var newUrl = new URL(window.location.href);
            newUrl.searchParams.set('lang', parts[1]);
            window.location.href = newUrl.toString();
            break;
          }
        }
      }
    });
    </script>
