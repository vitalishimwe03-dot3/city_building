<div class="text-center py-5">
  <div style="font-size: 64px; margin-bottom: 16px;">
    <i class="bi bi-shield-exclamation" style="color: #ef4444;"></i>
  </div>
  <h2 style="font-weight: 700; margin-bottom: 8px;"><%= title || 'Error' %></h2>
  <p style="color: var(--text-muted); max-width: 480px; margin: 0 auto;">
    <%= message || 'An unexpected error occurred.' %>
  </p>
  <a href="/admin/dashboard" class="btn btn-sm-custom btn-edit-custom mt-4">
    <i class="bi bi-arrow-left"></i> Back to Dashboard
  </a>
</div>