<section class="py-5">
  <div class="container">
    <h1 class="display-5 mb-4">Certificate</h1>
    <p class="lead">Upon successful completion of our courses, you will receive a professional certificate from City Building Engineering Company Ltd, recognized for its value in the industry.</p>
    <div class="row g-4 mt-4">
      <div class="col-lg-6">
        <div class="card shadow-sm p-4">
          <h2 class="h5">Sample Certificate</h2>
          <p class="text-muted">Here’s a preview of the certificate you will receive after completing our courses. It includes your name, the course title, and the date of completion.In message you will send number that is available on whatsapp</p>
          <div class="mt-3">
            <a href="#certificate-form" class="btn btn-outline-primary" id="jump-to-certificate-form">Request this certificate</a>
          </div>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="card shadow-sm p-4">
          <h2 class="h5 mb-3">Request Your Certificate</h2>
          <p class="text-muted">Provide your name, email, and a short message so we can follow up on your certificate request.</p>
          <form id="certificate-form" action="https://formspree.io/f/xnjyzgjr" method="POST">
            <input type="hidden" name="_subject" value="Certificate request from City Building website">
            <input type="hidden" name="course" value="Certificate Request">
            <div data-fs-success class="alert alert-success d-none" role="alert"></div>
            <div data-fs-error class="alert alert-danger d-none" role="alert"></div>
            <div class="mb-3">
              <label for="cert-name" class="form-label">Full Name</label>
              <input type="text" class="form-control" id="cert-name" name="name" data-fs-field required>
            </div>
            <div class="mb-3">
              <label for="cert-email" class="form-label">Email</label>
              <input type="email" class="form-control" id="cert-email" name="email" data-fs-field required>
            </div>
            <div class="mb-3">
              <label for="cert-message" class="form-label">Message</label>
              <textarea class="form-control" id="cert-message" name="message" rows="5" data-fs-field required></textarea>
            </div>
            <button type="submit" class="btn btn-primary" data-fs-submit-btn>Submit Request</button>
          </form>
          <script>
            window.formspree = window.formspree || function () { (formspree.q = formspree.q || []).push(arguments); };
            formspree('initForm', { formElement: '#certificate-form', formId: 'xnjyzgjr' });
          </script>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  (function(){
    const btn = document.getElementById('jump-to-certificate-form');
    if (!btn) return;
    btn.addEventListener('click', function(e){
      e.preventDefault();
      const form = document.getElementById('certificate-form');
      if (form) {
        form.scrollIntoView({ behavior: 'smooth', block: 'center' });
        // focus first input
        const first = form.querySelector('input,textarea,select');
        if (first) first.focus();
      }
    });
  })();
</script>

