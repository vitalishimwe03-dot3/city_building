<%- include('partials/ads', { slot: 'topBanner' }) %>

<section class="py-5">
  <div class="container">
    <div class="text-center mb-5">
      <p class="text-uppercase small fw-semibold mb-2" style="color: var(--accent-primary-light);">Student Work</p>
      <h1 class="display-5 fw-bold mb-3">Project Gallery</h1>
      <p class="lead text-muted mx-auto" style="max-width: 650px;">See what our students create. Real projects from Revit, AutoCAD, ETABS, Lumion, and more training courses.</p>
    </div>
    <% if (typeof projects !== 'undefined' && projects && projects.length > 0) { %>
      <div class="row g-4">
        <% projects.forEach(function(p) { %>
          <div class="col-sm-6 col-lg-4">
            <div class="card h-100 border-0 overflow-hidden" style="background: var(--bg-card); border: 1px solid var(--border); border-radius: 16px;">
              <% if (p.image_path) { %>
                <img src="<%= p.image_path %>" alt="<%= p.project_title %>" class="card-img-top" style="height: 220px; object-fit: cover;" loading="lazy">
              <% } else { %>
                <div style="height: 220px; background: linear-gradient(135deg, #0891b2, #06b6d4); display: flex; align-items: center; justify-content: center;">
                  <i class="bi bi-image" style="font-size: 3rem; color: rgba(255,255,255,0.4);"></i>
                </div>
              <% } %>
              <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-2">
                  <% if (p.is_featured) { %><span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> Featured</span><% } %>
                  <% if (p.course_name) { %><span class="badge" style="background: var(--accent-primary-light); color: #fff;"><%= p.course_name %></span><% } %>
                </div>
                <h3 class="h5 fw-bold mb-1"><%= p.project_title %></h3>
                <% if (p.student_name) { %><p class="small text-muted mb-2"><i class="bi bi-person"></i> <%= p.student_name %></p><% } %>
                <% if (p.description) { %><p class="small text-muted mb-0"><%= p.description %></p><% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } else { %>
      <div class="text-center py-5 text-muted">
        <i class="bi bi-images" style="font-size: 3rem; display: block; margin-bottom: 1rem; opacity: 0.4;"></i>
        <p>Gallery coming soon. Enroll and your project could be featured here!</p>
        <a href="/services" class="btn btn-primary">Explore Courses</a>
      </div>
    <% } %>
  </div>
</section>
