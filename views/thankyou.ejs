<section class="py-5 text-center">
  <div class="container">
    <div class="alert alert-success shadow-sm rounded-4 py-5">
      <h1 class="display-6">Thank you, <%= name %>!</h1>
      <p class="lead"><%= typeof message !== 'undefined' && message ? message : 'Your enquiry has been received. Our team will contact you soon.' %></p>
      <a href="/" class="btn btn-primary btn-lg mt-4">Back to homepage</a>
    </div>
  </div>
</section>
